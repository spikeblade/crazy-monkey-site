---
import LayoutPublic from '../layouts/LayoutPublic.astro';
---
<LayoutPublic
  title="Crazy Monkey — Collection Noir | Camisetas de Diseño Independiente"
  description="Crazy Monkey Collection Noir. Diseño independiente, gótico y disidente hecho en Colombia. 24 diseños en edición limitada desde $95.000 COP. Envío nacional."
  canonical="https://crazymonkey.store/"
  ogTitle="Crazy Monkey — Collection Noir"
  ogDescription="Diseño independiente, gótico y disidente hecho en Colombia. 24 diseños en edición limitada desde $95.000 COP."
  ogImage="https://crazymonkey.store/og-cover.jpg"
>
  <Fragment slot="head">
    <meta name="keywords" content="camisetas diseño independiente colombia, ropa gótica medellín, crazy monkey collection noir, camisetas alternativas colombia, ropa dark colombia">
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "ClothingStore",
      "name": "Crazy Monkey Collection Noir",
      "description": "Diseño independiente, gótico y disidente hecho en Colombia. Ediciones limitadas.",
      "url": "https://crazymonkey.store",
      "logo": "https://crazymonkey.store/favicon.svg",
      "image": "https://crazymonkey.store/og-cover.jpg",
      "telephone": "+573016568222",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Medellín",
        "addressCountry": "CO"
      },
      "priceRange": "$$",
      "currenciesAccepted": "COP",
      "paymentAccepted": "Tarjeta de crédito, PSE, Nequi, Daviplata, WhatsApp",
      "areaServed": "CO",
      "openingHours": "Mo-Su 00:00-23:59"
    }
    </script>
  </Fragment>

  <style is:global>
  #hero{min-height:100vh;display:flex;flex-direction:column;justify-content:center;align-items:center;position:relative;overflow:hidden;border-bottom:1px solid #1a1a1a}
  #hero::after{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 50% 60%,rgba(176,26,26,.12) 0%,transparent 70%);pointer-events:none}
  .hero-bg-text{position:absolute;font-family:'Bebas Neue',sans-serif;font-size:clamp(120px,22vw,320px);color:transparent;-webkit-text-stroke:1px rgba(176,26,26,.15);user-select:none;pointer-events:none;white-space:nowrap;top:50%;left:50%;transform:translate(-50%,-50%);z-index:0}
  .hero-content{position:relative;z-index:2;text-align:center;padding:2rem}
  .hero-eyebrow{font-family:'Space Mono',monospace;font-size:.65rem;letter-spacing:.5em;color:var(--red);text-transform:uppercase;margin-bottom:1.5rem;opacity:0;animation:fadeUp .8s ease .3s forwards}
  .hero-title{font-family:'UnifrakturMaguntia',cursive;font-size:clamp(52px,10vw,130px);line-height:.9;color:var(--white);text-shadow:0 0 80px rgba(176,26,26,.4),0 2px 0 #000;opacity:0;animation:fadeUp 1s ease .5s forwards}
  .hero-sub{font-family:'Bebas Neue',sans-serif;font-size:clamp(14px,3vw,28px);letter-spacing:.4em;color:var(--gold);margin-top:.6rem;opacity:0;animation:fadeUp 1s ease .8s forwards}
  .hero-divider{display:flex;align-items:center;gap:1rem;justify-content:center;margin:2rem auto;opacity:0;animation:fadeUp 1s ease 1s forwards}
  .hero-divider span{display:block;width:80px;height:1px;background:linear-gradient(90deg,transparent,var(--red))}
  .hero-divider span:last-child{background:linear-gradient(90deg,var(--red),transparent)}
  .hero-divider em{font-family:'Space Mono',monospace;font-size:.6rem;color:var(--light);letter-spacing:.3em;font-style:normal}
  .hero-cta{display:inline-block;font-family:'Bebas Neue',sans-serif;font-size:1.1rem;letter-spacing:.3em;color:var(--black);background:var(--red);padding:.8rem 2.5rem;text-decoration:none;margin-top:1rem;transition:background .2s,transform .2s;clip-path:polygon(8px 0%,100% 0%,calc(100% - 8px) 100%,0% 100%);opacity:0;animation:fadeUp 1s ease 1.2s forwards}
  .hero-cta:hover{background:var(--cream);transform:translateY(-2px)}
  .scroll-indicator{position:absolute;bottom:2rem;left:50%;transform:translateX(-50%);z-index:2;display:flex;flex-direction:column;align-items:center;gap:.4rem;opacity:0;animation:fadeIn 1s ease 2s forwards}
  .scroll-indicator span{font-size:.55rem;letter-spacing:.4em;color:var(--light)}
  .scroll-arrow{width:1px;height:40px;background:linear-gradient(180deg,var(--red),transparent);animation:scrollPulse 2s ease-in-out infinite}
  .marquee-section{border-top:1px solid #1a1a1a;border-bottom:1px solid #1a1a1a;padding:1rem 0;overflow:hidden;background:var(--deep)}
  .marquee-track{display:flex;animation:marqueeScroll 30s linear infinite;width:max-content}
  .marquee-item{font-family:'Bebas Neue',sans-serif;font-size:1rem;letter-spacing:.3em;color:var(--light);padding:0 3rem;white-space:nowrap;display:flex;align-items:center;gap:3rem}
  .marquee-item span.dot{display:inline-block;width:4px;height:4px;background:var(--red);border-radius:50%}
  .collections-strip{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));border-top:1px solid #1a1a1a;border-bottom:1px solid #1a1a1a}
  .collection-item{padding:3rem 2rem;border-right:1px solid #1a1a1a;text-align:center;transition:background .3s,box-shadow .2s;cursor:pointer;user-select:none}
  .collection-item:last-child{border-right:none}
  .collection-item:hover{background:rgba(176,26,26,.06)}
  .collection-item.active{background:rgba(176,26,26,.12);box-shadow:inset 0 -3px 0 var(--red)}
  .collection-item.active h3{color:var(--red)}
  .collection-icon{font-size:2rem;display:block;margin-bottom:1rem;transition:transform .3s}
  .collection-item:hover .collection-icon{transform:scale(1.15)}
  .collection-item h3{font-family:'Bebas Neue',sans-serif;font-size:1.3rem;letter-spacing:.15em;color:var(--white);margin-bottom:.5rem;transition:color .2s}
  .collection-item p{font-size:.65rem;letter-spacing:.1em;color:var(--light);line-height:1.8}
  .section-header{text-align:center;padding:6rem 2rem 3rem}
  .section-tag{font-family:'Space Mono',monospace;font-size:.6rem;letter-spacing:.5em;color:var(--red);text-transform:uppercase;display:block;margin-bottom:1rem}
  .section-title{font-family:'Bebas Neue',sans-serif;font-size:clamp(42px,7vw,90px);letter-spacing:.05em;color:var(--white);line-height:1}
  .section-rule{width:60px;height:2px;background:var(--red);margin:1.5rem auto 0}
  .tabs-wrapper{position:relative;margin-bottom:3rem}
  .tabs-wrapper::before,.tabs-wrapper::after{content:'';position:absolute;top:0;bottom:0;width:48px;pointer-events:none;z-index:1}
  .tabs-wrapper::before{left:0;background:linear-gradient(90deg,var(--black) 30%,transparent)}
  .tabs-wrapper::after{right:0;background:linear-gradient(-90deg,var(--black) 30%,transparent)}
  .collections-tabs{display:flex;overflow-x:auto;-webkit-overflow-scrolling:touch;scrollbar-width:none;border-bottom:1px solid #1e1e1e;padding:0 2rem}
  .collections-tabs::-webkit-scrollbar{display:none}
  .tab-btn{font-family:'Space Mono',monospace;font-size:.6rem;letter-spacing:.3em;text-transform:uppercase;background:none;border:none;color:var(--light);padding:.8rem 1.5rem;cursor:pointer;position:relative;transition:color .2s;white-space:nowrap;flex-shrink:0}
  .tab-btn::after{content:'';position:absolute;bottom:-1px;left:0;width:0;height:2px;background:var(--red);transition:width .3s}
  .tab-btn.active{color:var(--cream)}
  .tab-btn.active::after,.tab-btn:hover::after{width:100%}
  .tab-btn:hover{color:var(--cream)}
  .grid-section{padding:0 2rem 6rem;max-width:1400px;margin:0 auto}
  .shirts-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(340px,1fr));gap:2px}
  .shirt-card{position:relative;overflow:hidden;background:var(--deep);cursor:pointer}
  .shirt-card::before{content:'';position:absolute;inset:0;background:linear-gradient(180deg,transparent 30%,rgba(8,8,8,.95) 100%);z-index:2;pointer-events:none}
  .shirt-img{width:100%;aspect-ratio:16/9;object-fit:cover;display:block;transition:transform .6s cubic-bezier(.25,.46,.45,.94),filter .4s;filter:saturate(.9) contrast(1.05)}
  .shirt-card:hover .shirt-img{transform:scale(1.07);filter:saturate(1.1) contrast(1.1)}
  .card-info{position:absolute;bottom:0;left:0;right:0;z-index:3;padding:1.5rem}
  .card-collection{font-size:.5rem;letter-spacing:.4em;color:var(--red);text-transform:uppercase;margin-bottom:.3rem}
  .card-name{font-family:'Bebas Neue',sans-serif;font-size:1.4rem;letter-spacing:.1em;color:var(--white);line-height:1.1}
  .card-desc{font-size:.58rem;line-height:1.7;color:var(--cream);margin-top:.5rem;max-height:0;overflow:hidden;opacity:0;transition:max-height .4s ease,opacity .3s ease}
  .shirt-card:hover .card-desc{max-height:120px;opacity:1}
  .card-price{font-family:'Space Mono',monospace;font-size:.75rem;color:var(--gold);margin-top:.5rem;opacity:0;transition:opacity .3s .1s}
  .shirt-card:hover .card-price{opacity:1}
  .card-cta{display:inline-block;margin-top:.6rem;font-family:'Space Mono',monospace;font-size:.55rem;letter-spacing:.3em;text-transform:uppercase;color:var(--black);background:var(--red);padding:.4rem 1rem;text-decoration:none;opacity:0;transform:translateY(8px);transition:opacity .3s .15s,transform .3s .15s,background .2s}
  .shirt-card:hover .card-cta{opacity:1;transform:translateY(0)}
  .card-cta:hover{background:var(--cream)}
  .card-agotado-badge{position:absolute;top:.8rem;right:.8rem;z-index:4;font-family:'Space Mono',monospace;font-size:.45rem;letter-spacing:.2em;color:#555;background:rgba(8,8,8,.85);border:1px solid #333;padding:.2rem .6rem;text-transform:uppercase}
  .shirt-card.agotado{cursor:default}
  .shirt-card.agotado .shirt-img{filter:saturate(0) contrast(.7);opacity:.6}
  @media(max-width:768px){
    .shirts-grid{grid-template-columns:1fr;gap:2px}
    .collections-strip{grid-template-columns:repeat(auto-fill,minmax(160px,1fr))}
    .collection-item{border-right:none;border-bottom:1px solid #1a1a1a;padding:2rem 1.5rem}
    .tab-btn{font-size:.55rem;padding:.7rem 1rem}
  }
  </style>

  <!-- HERO -->
  <section id="hero">
    <div class="hero-bg-text">NOIR</div>
    <div class="hero-content">
      <p class="hero-eyebrow">✦ Crazy Monkey Shirts ✦ Est. MMXXIV ✦</p>
      <h1 class="hero-title">Collection<br>Noir</h1>
      <p class="hero-sub">Gótico · Editorial · Disidente</p>
      <div class="hero-divider"><span></span><em>24 diseños · Edición Limitada</em><span></span></div>
      <a href="#coleccion" class="hero-cta">Ver Colección</a>
    </div>
    <div class="scroll-indicator"><div class="scroll-arrow"></div><span>Scroll</span></div>
  </section>

  <!-- MARQUEE -->
  <div class="marquee-section">
    <div class="marquee-track">
      <div class="marquee-item">Non Serviam <span class="dot"></span> Gothic Fantasy <span class="dot"></span> Celluloid Guerrilla <span class="dot"></span> Collection Noir <span class="dot"></span> Polygon Heist <span class="dot"></span> Horror Decade <span class="dot"></span> De Tus Cenizas <span class="dot"></span> Nevermore <span class="dot"></span> Violencia y Estilo <span class="dot"></span> Override 90's <span class="dot"></span> D.I.Y. o Muere <span class="dot"></span> La Realidad Ya No Vive Aquí <span class="dot"></span></div>
      <div class="marquee-item" aria-hidden="true">Non Serviam <span class="dot"></span> Gothic Fantasy <span class="dot"></span> Celluloid Guerrilla <span class="dot"></span> Collection Noir <span class="dot"></span> Polygon Heist <span class="dot"></span> Horror Decade <span class="dot"></span> De Tus Cenizas <span class="dot"></span> Nevermore <span class="dot"></span> Violencia y Estilo <span class="dot"></span> Override 90's <span class="dot"></span> D.I.Y. o Muere <span class="dot"></span> La Realidad Ya No Vive Aquí <span class="dot"></span></div>
    </div>
  </div>

  <!-- COLLECTIONS STRIP — dinámico desde Supabase -->
  <div class="collections-strip" id="collectionsStrip"></div>

  <!-- CATÁLOGO -->
  <section id="coleccion">
    <div class="section-header">
      <span class="section-tag">✦ Catálogo Completo ✦</span>
      <h2 class="section-title">Los Diseños</h2>
      <div class="section-rule"></div>
    </div>
    <div class="tabs-wrapper">
      <div class="collections-tabs" id="categoriasTabs"></div>
    </div>
    <div class="grid-section">
      <div class="shirts-grid" id="shirtsGrid">
        <div style="grid-column:1/-1;text-align:center;padding:4rem;font-size:.6rem;letter-spacing:.3em;color:#333;text-transform:uppercase" id="catalogLoading">
          Cargando colección...
        </div>
      </div>
    </div>
  </section>

  <script is:inline>
  // ── Estado de filtros ──────────────────────────────────────────────────────
  var activeCategory = 'all';
  var activeCollection = null;

  function applyFilters() {
    document.querySelectorAll('.shirt-card').forEach(function(card) {
      var catOk = activeCategory === 'all' || card.dataset.cat === activeCategory;
      var colOk = !activeCollection || card.dataset.coleccion === activeCollection;
      card.style.display = (catOk && colOk) ? '' : 'none';
    });
  }

  // ── Strip de colecciones (dinámico) ────────────────────────────────────────
  var STRIP_ICONS = ['🜏', '†', '⚡', '✦', '☽', '⚔', '◈', '🕯'];

  function buildStrip(colecciones) {
    var strip = document.getElementById('collectionsStrip');
    strip.innerHTML = '';
    if (!colecciones || colecciones.length === 0) {
      strip.style.display = 'none';
      return;
    }
    colecciones.forEach(function(col, i) {
      var item = document.createElement('div');
      item.className = 'collection-item';
      item.dataset.coleccion = col.nombre.toLowerCase();
      item.innerHTML =
        '<span class="collection-icon">' + STRIP_ICONS[i % STRIP_ICONS.length] + '</span>' +
        '<h3>' + col.nombre + '</h3>' +
        (col.descripcion ? '<p>' + col.descripcion + '</p>' : '');
      strip.appendChild(item);
    });
    strip.addEventListener('click', function(e) {
      var item = e.target.closest('.collection-item');
      if (!item) return;
      var col = item.dataset.coleccion;
      if (activeCollection === col) {
        activeCollection = null;
        item.classList.remove('active');
      } else {
        document.querySelectorAll('.collection-item').forEach(function(el) { el.classList.remove('active'); });
        item.classList.add('active');
        activeCollection = col;
      }
      applyFilters();
      document.getElementById('coleccion').scrollIntoView({ behavior: 'smooth' });
    });
  }

  // ── Tabs de categorías (dinámico) ─────────────────────────────────────────
  function buildTabs(categorias) {
    var container = document.getElementById('categoriasTabs');
    container.innerHTML = '';

    // "Todos" siempre primero
    var allBtn = document.createElement('button');
    allBtn.className = 'tab-btn active';
    allBtn.dataset.filter = 'all';
    allBtn.textContent = 'Todos';
    container.appendChild(allBtn);

    (categorias || []).forEach(function(cat) {
      var btn = document.createElement('button');
      btn.className = 'tab-btn';
      btn.dataset.filter = cat.slug;
      btn.textContent = cat.nombre;
      container.appendChild(btn);
    });

    container.addEventListener('click', function(e) {
      var btn = e.target.closest('.tab-btn');
      if (!btn) return;
      document.querySelectorAll('.tab-btn').forEach(function(t) { t.classList.remove('active'); });
      btn.classList.add('active');
      activeCategory = btn.dataset.filter;
      applyFilters();
    });
  }

  // ── Render de productos ───────────────────────────────────────────────────
  function renderProductos(productos) {
    var grid = document.getElementById('shirtsGrid');
    var loadingEl = document.getElementById('catalogLoading');

    if (!productos || productos.length === 0) {
      if (loadingEl) loadingEl.textContent = 'No hay productos disponibles.';
      return;
    }

    localStorage.setItem('cm_catalog', JSON.stringify(productos.map(function(p) {
      return { img: p.imagen, imagenes: p.imagenes || null, name: p.nombre, collection: p.coleccion,
        desc: p.descripcion, cat: p.categoria, price: p.precio, stock_tallas: p.stock_tallas || null };
    })));

    if (loadingEl) loadingEl.remove();

    productos.forEach(function(p) {
      var agotado = p.stock_total !== null && p.stock_total !== undefined
        && (p.stock_vendido || 0) >= p.stock_total;

      var card = document.createElement('div');
      card.className = 'shirt-card' + (agotado ? ' agotado' : '');
      card.dataset.cat = p.categoria;
      card.dataset.coleccion = (p.coleccion || '').toLowerCase();

      var precioHtml = agotado
        ? '<span style="color:#555;text-decoration:line-through">$' + p.precio.toLocaleString('es-CO') + ' COP</span>'
        : '$' + p.precio.toLocaleString('es-CO') + ' COP';
      var ctaHtml = agotado
        ? '<button class="card-cta" disabled style="background:#333;color:#666;cursor:not-allowed">Agotado</button>'
        : '<button class="card-cta">Ver diseño →</button>';

      card.innerHTML =
        (agotado ? '<span class="card-agotado-badge">Agotado</span>' : '') +
        '<img class="shirt-img" src="' + p.imagen + '" alt="' + p.nombre + '" loading="lazy">' +
        '<div class="card-info">' +
          '<p class="card-collection">' + p.coleccion + '</p>' +
          '<h3 class="card-name">' + p.nombre + '</h3>' +
          '<p class="card-desc">' + p.descripcion + '</p>' +
          '<p class="card-price">' + precioHtml + '</p>' +
          ctaHtml +
        '</div>';

      card.addEventListener('click', function() {
        localStorage.setItem('cm_current_product', JSON.stringify({
          img: p.imagen, imagenes: p.imagenes || null, name: p.nombre, collection: p.coleccion,
          desc: p.descripcion, cat: p.categoria, price: p.precio, stock_tallas: p.stock_tallas || null,
        }));
        window.location.href = '/producto.html';
      });

      grid.appendChild(card);
    });
  }

  // ── Carga paralela ────────────────────────────────────────────────────────
  async function loadAll() {
    try {
      var results = await Promise.all([
        fetch('/.netlify/functions/taxonomias?tipo=colecciones').then(function(r) { return r.ok ? r.json() : []; }).catch(function() { return []; }),
        fetch('/.netlify/functions/taxonomias?tipo=categorias').then(function(r) { return r.ok ? r.json() : []; }).catch(function() { return []; }),
        fetch('/.netlify/functions/productos').then(function(r) {
          if (!r.ok) throw new Error('Error cargando catálogo');
          return r.json();
        }),
      ]);
      var colecciones = results[0];
      var categorias = results[1];
      var productos = results[2];

      buildStrip(colecciones);
      buildTabs(categorias);
      renderProductos(productos);

      // Si viene ?coleccion= en la URL, activar el strip correspondiente
      var params = new URLSearchParams(window.location.search);
      var colParam = params.get('coleccion');
      if (colParam) {
        var target = document.querySelector('.collection-item[data-coleccion="' + colParam.toLowerCase() + '"]');
        if (target) target.click();
        else {
          // fallback: filtrar directamente por nombre de colección en las cards
          activeCollection = colParam.toLowerCase();
          applyFilters();
          setTimeout(function() { document.getElementById('coleccion').scrollIntoView({ behavior: 'smooth' }); }, 100);
        }
      }
    } catch(e) {
      console.error('Catalog load error:', e);
      var loadingEl = document.getElementById('catalogLoading');
      if (loadingEl) loadingEl.textContent = 'Error cargando productos. Recarga la página.';
    }
  }

  loadAll();
  </script>
</LayoutPublic>
