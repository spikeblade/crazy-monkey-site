---
import LayoutPublic from '../layouts/LayoutPublic.astro';
---
<LayoutPublic
  title="Colecciones — CRAZY MONKEY"
  description="Explora las colecciones de Crazy Monkey Collection Noir. Gótico, disidente e independiente hecho en Colombia."
  canonical="https://crazymonkey.store/colecciones.html"
  ogTitle="Colecciones — CRAZY MONKEY"
  ogDescription="Explora las colecciones de Crazy Monkey Collection Noir."
  ogImage="https://crazymonkey.store/og-cover.jpg"
>
  <style is:global>
  #colecciones-page{padding:8rem 2rem 6rem;max-width:1200px;margin:0 auto}
  .col-header{text-align:center;margin-bottom:4rem}
  .col-tag{font-family:'Space Mono',monospace;font-size:.6rem;letter-spacing:.5em;color:var(--red);text-transform:uppercase;display:block;margin-bottom:1rem}
  .col-title{font-family:'Bebas Neue',sans-serif;font-size:clamp(42px,7vw,90px);letter-spacing:.05em;color:var(--white);line-height:1}
  .col-rule{width:60px;height:2px;background:var(--red);margin:1.5rem auto 0}
  .col-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(340px,1fr));gap:2px}
  .col-card{position:relative;background:var(--deep);border:1px solid #1a1a1a;padding:3rem 2.5rem;cursor:pointer;transition:border-color .3s,background .3s;text-decoration:none;display:block}
  .col-card:hover{border-color:var(--red);background:rgba(176,26,26,.04)}
  .col-card-num{font-family:'Cinzel Decorative',serif;font-size:3rem;color:rgba(176,26,26,.15);line-height:1;margin-bottom:1.5rem}
  .col-card-name{font-family:'Bebas Neue',sans-serif;font-size:1.6rem;letter-spacing:.12em;color:var(--white);margin-bottom:.8rem}
  .col-card-desc{font-size:.68rem;line-height:2;color:var(--light);margin-bottom:1.5rem}
  .col-card-count{font-family:'Space Mono',monospace;font-size:.5rem;letter-spacing:.3em;color:var(--red);text-transform:uppercase}
  .col-card-arrow{position:absolute;bottom:2rem;right:2rem;font-family:'Space Mono',monospace;font-size:.6rem;color:#2a2a2a;transition:color .3s,transform .3s}
  .col-card:hover .col-card-arrow{color:var(--red);transform:translateX(4px)}
  .col-inactive{opacity:.35;pointer-events:none}
  .col-empty{grid-column:1/-1;text-align:center;padding:4rem;font-size:.6rem;letter-spacing:.3em;color:#333;text-transform:uppercase}
  .col-loading{grid-column:1/-1;text-align:center;padding:4rem;font-size:.6rem;letter-spacing:.3em;color:#333;text-transform:uppercase}
  </style>

  <div id="colecciones-page">
    <div class="col-header">
      <span class="col-tag">✦ Crazy Monkey ✦</span>
      <h1 class="col-title">Colecciones</h1>
      <div class="col-rule"></div>
    </div>
    <div class="col-grid" id="colGrid">
      <div class="col-loading">Cargando colecciones...</div>
    </div>
  </div>

  <script is:inline>
  var ROMAN = ['I','II','III','IV','V','VI','VII','VIII','IX','X'];

  async function loadColecciones() {
    var grid = document.getElementById('colGrid');
    try {
      var [colRes, prodRes] = await Promise.all([
        fetch('/.netlify/functions/taxonomias?tipo=colecciones'),
        fetch('/.netlify/functions/productos'),
      ]);
      var colecciones = await colRes.json();
      var productos = await prodRes.json();

      if (!Array.isArray(colecciones) || !colecciones.length) {
        grid.innerHTML = '<div class="col-empty">Sin colecciones disponibles.</div>';
        return;
      }

      // Contar productos activos por colección
      var countByCol = {};
      if (Array.isArray(productos)) {
        productos.forEach(function(p) {
          var key = (p.coleccion || '').toLowerCase();
          countByCol[key] = (countByCol[key] || 0) + 1;
        });
      }

      grid.innerHTML = colecciones.map(function(c, i) {
        var count = countByCol[(c.nombre || '').toLowerCase()] || 0;
        var inactiva = c.activo === false;
        return '<a href="/index.html?coleccion=' + encodeURIComponent(c.nombre) + '" class="col-card' + (inactiva ? ' col-inactive' : '') + '">' +
          '<div class="col-card-num">' + (ROMAN[i] || (i + 1)) + '</div>' +
          '<div class="col-card-name">' + c.nombre + '</div>' +
          (c.descripcion ? '<div class="col-card-desc">' + c.descripcion + '</div>' : '') +
          '<div class="col-card-count">' + count + ' ' + (count === 1 ? 'diseño' : 'diseños') + '</div>' +
          '<span class="col-card-arrow">→</span>' +
        '</a>';
      }).join('');
    } catch(e) {
      grid.innerHTML = '<div class="col-empty">Error cargando colecciones.</div>';
    }
  }

  loadColecciones();
  </script>
</LayoutPublic>
