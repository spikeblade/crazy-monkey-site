---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Pago No Completado — CRAZY MONKEY" noindex={true}>
  <style is:global>
  body{min-height:100vh;display:flex;flex-direction:column}
  nav{position:fixed;top:0;left:0;right:0;z-index:1000;display:flex;justify-content:space-between;align-items:center;padding:1.2rem 2.5rem;background:rgba(8,8,8,0.98)}
  main{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:8rem 2rem 4rem;text-align:center;position:relative;z-index:1}
  .status-icon{font-size:2.5rem;margin-bottom:2rem;display:block;opacity:.5}
  .page-eyebrow{font-family:'Space Mono',monospace;font-size:.6rem;letter-spacing:.5em;color:var(--light);text-transform:uppercase;margin-bottom:1.2rem;opacity:0;animation:fadeUp .8s ease .2s forwards}
  .page-title{font-family:'UnifrakturMaguntia',cursive;font-size:clamp(42px,8vw,96px);line-height:.95;color:var(--white);text-shadow:0 0 40px rgba(176,26,26,.2),0 2px 0 #000;margin-bottom:1rem;opacity:0;animation:fadeUp 1s ease .4s forwards}
  .page-sub{font-family:'Bebas Neue',sans-serif;font-size:clamp(12px,2vw,18px);letter-spacing:.4em;color:var(--light);margin-bottom:2rem;opacity:0;animation:fadeUp 1s ease .6s forwards}
  .page-divider{display:flex;align-items:center;gap:1rem;justify-content:center;margin:1.5rem auto 2.5rem;opacity:0;animation:fadeUp 1s ease .8s forwards}
  .page-divider span{display:block;width:60px;height:1px;background:linear-gradient(90deg,transparent,#2a2a2a)}
  .page-divider span:last-child{background:linear-gradient(90deg,#2a2a2a,transparent)}
  .page-divider em{font-size:.55rem;color:#333;letter-spacing:.3em;font-style:normal}
  .message-block{font-size:.72rem;line-height:2.2;color:var(--light);max-width:480px;margin:0 auto 3rem;opacity:0;animation:fadeUp 1s ease 1s forwards}
  .message-block strong{color:var(--cream)}
  .options-grid{display:grid;grid-template-columns:1fr 1fr;gap:1.5rem;max-width:560px;margin:0 auto 2rem;opacity:0;animation:fadeUp 1s ease 1.2s forwards}
  .option-card{border:1px solid #1e1e1e;padding:2rem 1.5rem;text-align:center;transition:border-color .3s,background .3s;text-decoration:none;display:block}
  .option-card:hover{border-color:var(--red);background:rgba(176,26,26,.04)}
  .option-card .option-icon{font-size:1.4rem;display:block;margin-bottom:.8rem;color:var(--red)}
  .option-card h3{font-family:'Bebas Neue',sans-serif;font-size:1rem;letter-spacing:.15em;color:var(--white);margin-bottom:.5rem}
  .option-card p{font-size:.55rem;letter-spacing:.1em;color:var(--light);line-height:1.8}
  .retry-btn{font-family:'Bebas Neue',sans-serif;font-size:1rem;letter-spacing:.3em;color:var(--black);background:var(--red);padding:.8rem 2.5rem;text-decoration:none;clip-path:polygon(8px 0%,100% 0%,calc(100% - 8px) 100%,0% 100%);transition:background .2s,transform .2s;display:inline-block;opacity:0;animation:fadeUp 1s ease 1.4s forwards}
  .retry-btn:hover{background:var(--cream);transform:translateY(-2px)}
  @media(max-width:768px){nav{padding:1rem 1.5rem}.options-grid{grid-template-columns:1fr}}
  </style>

<nav>
  <a href="/index.html" class="nav-logo">Crazy<span>M</span>onkey</a>
</nav>

<main>
  <span class="status-icon">✕</span>
  <p class="page-eyebrow">Pago no completado</p>
  <h1 class="page-title">Sin<br>Problema</h1>
  <p class="page-sub">Tu carrito sigue intacto</p>
  <div class="page-divider"><span></span><em>Intentémoslo de nuevo</em><span></span></div>

  <div class="message-block">
    El pago no se procesó — puede haber sido cancelado, rechazado, o simplemente decidiste volver.<br>
    <strong>Tu carrito no se borró.</strong> Puedes intentar de nuevo con MercadoPago o completar tu pedido directamente por WhatsApp.
  </div>

  <div class="options-grid">
    <a href="/index.html#coleccion" class="option-card">
      <span class="option-icon">↩</span>
      <h3>Volver al carrito</h3>
      <p>Revisa tu selección e intenta el pago de nuevo</p>
    </a>
    <a href="https://wa.me/573016568222?text=Hola!%20Quiero%20hacer%20un%20pedido%20pero%20tuve%20problemas%20con%20el%20pago." target="_blank" rel="noopener" class="option-card">
      <span class="option-icon">✆</span>
      <h3>Pedir por WhatsApp</h3>
      <p>Coordinamos el pago directamente contigo</p>
    </a>
  </div>

  <a href="/index.html" class="retry-btn">Regresar a la tienda →</a>
</main>
</Layout>
