---
import LayoutPublic from '../layouts/LayoutPublic.astro';
---
<LayoutPublic
  title="Producto — CRAZY MONKEY"
  description="Diseño independiente, gótico y disidente hecho en Colombia. Edición limitada."
  canonical="https://crazymonkey.store/producto.html"
  ogTitle="Producto — CRAZY MONKEY"
  ogDescription="Diseño independiente, gótico y disidente hecho en Colombia. Edición limitada."
  ogImage="https://crazymonkey.store/og-cover.jpg"
  cartCheckoutFn="checkout"
>
  <style is:global>
  main{padding-top:5rem;min-height:100vh;display:flex;align-items:stretch}
  .product-wrap{display:grid;grid-template-columns:1fr 1fr;max-width:1200px;margin:0 auto;width:100%;min-height:calc(100vh - 5rem)}
  .product-image-col{position:relative;background:var(--deep);overflow:hidden;border-right:1px solid #1a1a1a;display:flex;flex-direction:column}
  .gallery-main{flex:1;position:relative;overflow:hidden;min-height:0}
  .gallery-thumbs{display:flex;gap:2px;padding:2px;background:var(--black);border-top:1px solid #1a1a1a;flex-shrink:0}
  .gallery-thumb{width:70px;height:70px;object-fit:cover;cursor:pointer;opacity:.45;border:2px solid transparent;transition:opacity .2s,border-color .2s;flex-shrink:0;filter:saturate(.7)}
  .gallery-thumb.active{opacity:1;border-color:var(--red);filter:saturate(1)}
  .product-img{width:100%;height:100%;object-fit:cover;display:block;filter:saturate(.95) contrast(1.05);transition:transform .6s cubic-bezier(.25,.46,.45,.94)}
  .product-img:hover{transform:scale(1.03)}
  .product-collection-badge{position:absolute;top:1.5rem;left:1.5rem;font-size:.5rem;letter-spacing:.4em;color:var(--red);text-transform:uppercase;background:rgba(8,8,8,.8);padding:.3rem .7rem;border:1px solid rgba(176,26,26,.3)}
  .img-placeholder{width:100%;height:100%;min-height:60vh;background:var(--deep);display:flex;align-items:center;justify-content:center}
  .img-placeholder span{font-family:'UnifrakturMaguntia',cursive;font-size:6rem;color:#1a1a1a}
  .product-info-col{padding:4rem 3.5rem;display:flex;flex-direction:column;justify-content:center;gap:1.5rem;background:var(--black)}
  .product-eyebrow{font-size:.55rem;letter-spacing:.5em;color:var(--red);text-transform:uppercase}
  .product-name{font-family:'UnifrakturMaguntia',cursive;font-size:clamp(38px,5vw,68px);line-height:.95;color:var(--white);text-shadow:0 0 40px rgba(176,26,26,.3),0 2px 0 #000}
  .product-divider{display:flex;align-items:center;gap:1rem}
  .product-divider span{display:block;width:40px;height:1px;background:linear-gradient(90deg,var(--red),transparent)}
  .product-desc{font-size:.75rem;line-height:2;color:var(--light);max-width:420px}
  .product-price{font-family:'Space Mono',monospace;font-size:1.1rem;color:var(--gold);letter-spacing:.05em}
  .product-price small{font-size:.6rem;color:var(--light);margin-left:.4rem;letter-spacing:.2em}
  .stock-badge{display:inline-flex;align-items:center;gap:.4rem;font-size:.55rem;letter-spacing:.25em;text-transform:uppercase;padding:.3rem .8rem;border-radius:2px;margin-top:.3rem}
  .stock-limitada{background:rgba(176,26,26,.1);border:1px solid rgba(176,26,26,.25);color:var(--red)}
  .stock-pocas{background:rgba(200,168,75,.1);border:1px solid rgba(200,168,75,.3);color:var(--gold)}
  .stock-agotado{background:rgba(85,85,85,.15);border:1px solid #333;color:#555}
  .stock-dot{width:5px;height:5px;border-radius:50%;flex-shrink:0}
  .stock-dot-red{background:var(--red)}
  .stock-dot-gold{background:var(--gold);animation:pulseDot 1.5s ease-in-out infinite}
  .stock-dot-gray{background:#444}
  @keyframes pulseDot{0%,100%{opacity:.4;transform:scale(1)}50%{opacity:1;transform:scale(1.3)}}
  .size-section{display:flex;flex-direction:column;gap:.7rem}
  .size-label{font-size:.5rem;letter-spacing:.4em;color:var(--light);text-transform:uppercase}
  .size-options{display:flex;gap:.5rem;flex-wrap:wrap}
  .size-btn{background:none;border:1px solid #2a2a2a;color:var(--light);font-family:'Space Mono',monospace;font-size:.65rem;padding:.5rem .9rem;cursor:pointer;transition:all .2s;letter-spacing:.1em;min-width:48px;text-align:center}
  .size-btn:hover{border-color:var(--cream);color:var(--cream)}
  .size-btn.selected{border-color:var(--red);color:var(--white);background:rgba(176,26,26,.15)}
  .size-note{font-size:.55rem;color:var(--red);min-height:.8rem;letter-spacing:.1em}
  .size-guide-toggle{font-size:.5rem;letter-spacing:.25em;color:#444;cursor:pointer;text-transform:uppercase;text-decoration:underline;text-underline-offset:3px;transition:color .2s;background:none;border:none;padding:0}
  .size-guide-toggle:hover{color:var(--light)}
  .tallas-modal-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.92);z-index:30000;align-items:center;justify-content:center;padding:2rem;cursor:zoom-out}
  .tallas-modal-overlay.open{display:flex}
  .tallas-modal{background:#0d0d0d;border:1px solid #2a2a2a;border-top:3px solid var(--red);max-width:640px;width:100%;max-height:90vh;overflow-y:auto;cursor:default}
  .tallas-modal-header{display:flex;justify-content:space-between;align-items:center;padding:1.5rem 2rem;border-bottom:1px solid #1e1e1e}
  .tallas-modal-title{font-family:'Bebas Neue',sans-serif;font-size:1.3rem;letter-spacing:.2em;color:var(--white)}
  .tallas-modal-close{background:none;border:none;color:var(--light);font-size:1rem;cursor:pointer;font-family:'Space Mono',monospace;transition:color .2s}
  .tallas-modal-close:hover{color:var(--cream)}
  .tallas-modal-body{padding:1.5rem 2rem 2rem}
  .tallas-eyebrow{font-size:.5rem;letter-spacing:.4em;color:var(--red);text-transform:uppercase;margin-bottom:1.2rem}
  .tallas-table{width:100%;border-collapse:collapse;font-size:.65rem;margin-bottom:1.5rem}
  .tallas-table thead tr{border-bottom:1px solid #2a2a2a}
  .tallas-table th{font-size:.5rem;letter-spacing:.3em;color:var(--red);text-transform:uppercase;padding:.6rem .8rem;text-align:center;font-weight:400}
  .tallas-table th:first-child{text-align:left}
  .tallas-table td{padding:.7rem .8rem;border-bottom:1px solid #111;color:var(--light);text-align:center;transition:background .2s}
  .tallas-table td:first-child{color:var(--white);font-family:'Bebas Neue',sans-serif;font-size:.9rem;letter-spacing:.1em;text-align:left}
  .tallas-table tr:hover td{background:rgba(176,26,26,.04)}
  .tallas-table tr:last-child td{border-bottom:none}
  .tallas-highlight td{background:rgba(176,26,26,.1)!important;color:var(--cream)!important}
  .tallas-highlight td:first-child{color:var(--white)!important}
  .tallas-measure-title{font-family:'Bebas Neue',sans-serif;font-size:.9rem;letter-spacing:.15em;color:var(--white);margin:1.5rem 0 .8rem}
  .tallas-measure-list{display:flex;flex-direction:column;gap:.5rem;margin-bottom:1.2rem}
  .tallas-measure-item{display:flex;gap:.8rem;align-items:flex-start;font-size:.6rem;line-height:1.7}
  .tallas-measure-num{font-family:'Bebas Neue',sans-serif;font-size:.85rem;color:var(--red);min-width:1.2rem;flex-shrink:0}
  .tallas-measure-text{color:var(--light)}
  .tallas-measure-text strong{color:var(--cream)}
  .tallas-tip{background:rgba(176,26,26,.05);border-left:2px solid var(--red);padding:.8rem 1rem;margin-top:1rem;font-size:.58rem;line-height:1.9;color:var(--light)}
  .tallas-tip strong{color:var(--cream)}
  .tallas-note{font-size:.58rem;line-height:2;color:var(--light);border-top:1px solid #1a1a1a;padding-top:1.2rem;margin-top:1.2rem}
  .tallas-note strong{color:var(--cream)}
  .add-to-cart-btn{font-family:'Bebas Neue',sans-serif;font-size:1.1rem;letter-spacing:.3em;color:var(--black);background:var(--red);border:none;padding:1rem 2.5rem;cursor:pointer;clip-path:polygon(8px 0%,100% 0%,calc(100% - 8px) 100%,0% 100%);transition:background .2s,transform .2s;align-self:flex-start}
  .add-to-cart-btn:hover{background:var(--cream);transform:translateY(-2px)}
  .add-to-cart-btn:disabled{background:#333;color:#666;cursor:not-allowed;transform:none}
  .add-to-cart-btn.added{background:var(--gold);color:var(--black)}
  .product-details{display:flex;flex-direction:column;gap:.5rem;border-top:1px solid #1a1a1a;padding-top:1.5rem;margin-top:.5rem}
  .detail-row{display:flex;gap:1rem;font-size:.58rem;align-items:baseline}
  .detail-key{color:var(--light);letter-spacing:.2em;text-transform:uppercase;min-width:80px;flex-shrink:0}
  .detail-val{color:var(--cream);line-height:1.7}
  .related-section{border-top:1px solid #1a1a1a;padding:4rem 2rem;max-width:1200px;margin:0 auto}
  .related-header{font-family:'Bebas Neue',sans-serif;font-size:1.2rem;letter-spacing:.2em;color:var(--white);margin-bottom:2rem}
  .related-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:2px}
  .related-card{position:relative;overflow:hidden;background:var(--deep);cursor:pointer;aspect-ratio:4/3}
  .related-card::before{content:'';position:absolute;inset:0;background:linear-gradient(180deg,transparent 40%,rgba(8,8,8,.9) 100%);z-index:2}
  .related-card img{width:100%;height:100%;object-fit:cover;transition:transform .5s;filter:saturate(.85)}
  .related-card:hover img{transform:scale(1.06)}
  .related-card-info{position:absolute;bottom:0;left:0;right:0;z-index:3;padding:1rem}
  .related-card-name{font-family:'Bebas Neue',sans-serif;font-size:.95rem;letter-spacing:.08em;color:var(--white)}
  .related-card-price{font-size:.55rem;color:var(--gold);margin-top:.2rem}
  .reviews-section{max-width:1200px;margin:0 auto;padding:4rem 2rem 6rem;border-top:1px solid #1a1a1a}
  .reviews-header{display:flex;justify-content:space-between;align-items:baseline;margin-bottom:2.5rem;flex-wrap:wrap;gap:1rem}
  .reviews-title{font-family:'Bebas Neue',sans-serif;font-size:1.4rem;letter-spacing:.15em;color:var(--white)}
  .reviews-summary{display:flex;align-items:center;gap:.8rem}
  .reviews-avg{font-family:'Bebas Neue',sans-serif;font-size:2rem;letter-spacing:.05em;color:var(--gold)}
  .reviews-stars-row{display:flex;gap:2px}
  .star{font-size:.9rem;color:#2a2a2a;transition:color .1s}
  .star.filled{color:var(--gold)}
  .reviews-count{font-size:.55rem;letter-spacing:.25em;color:var(--light);text-transform:uppercase}
  .reviews-list{display:flex;flex-direction:column;gap:1.2rem;margin-bottom:3rem}
  .review-card{border:1px solid #1e1e1e;padding:1.5rem;transition:border-color .2s}
  .review-card:hover{border-color:#2a2a2a}
  .review-card-top{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:.8rem;gap:1rem;flex-wrap:wrap}
  .review-autor{font-family:'Bebas Neue',sans-serif;font-size:.9rem;letter-spacing:.1em;color:var(--white)}
  .review-date{font-size:.5rem;letter-spacing:.2em;color:var(--light);text-transform:uppercase}
  .review-stars{display:flex;gap:2px;margin-bottom:.6rem}
  .review-comentario{font-size:.7rem;line-height:1.9;color:var(--cream)}
  .reviews-empty{font-size:.65rem;letter-spacing:.2em;color:#444;text-align:center;padding:2.5rem 0}
  .review-form-wrap{border:1px solid #1e1e1e;border-left:3px solid var(--red);padding:2rem;background:rgba(176,26,26,.03)}
  .review-form-title{font-family:'Bebas Neue',sans-serif;font-size:1.1rem;letter-spacing:.15em;color:var(--white);margin-bottom:1.5rem}
  .star-picker{display:flex;gap:.4rem;margin-bottom:1.2rem}
  .star-pick{font-size:1.4rem;color:#2a2a2a;cursor:pointer;transition:color .15s;background:none;border:none;padding:0;line-height:1}
  .star-pick:hover,.star-pick.active{color:var(--gold)}
  .review-input{background:#111;border:1px solid #2a2a2a;border-bottom:1px solid var(--red);color:var(--cream);font-family:'Space Mono',monospace;font-size:.72rem;padding:.7rem 1rem;outline:none;transition:border-color .2s;resize:none;width:100%;margin-bottom:1rem}
  .review-input:focus{border-color:var(--cream);background:#161616}
  .review-input::placeholder{color:#444}
  .review-submit{font-family:'Bebas Neue',sans-serif;font-size:.95rem;letter-spacing:.25em;color:var(--black);background:var(--red);border:none;padding:.75rem 2rem;cursor:pointer;clip-path:polygon(6px 0%,100% 0%,calc(100% - 6px) 100%,0% 100%);transition:background .2s}
  .review-submit:hover{background:var(--cream)}
  .review-submit:disabled{background:#333;color:#666;cursor:not-allowed}
  .review-msg{font-size:.6rem;margin-top:.8rem;min-height:1rem;letter-spacing:.1em}
  .review-msg.error{color:var(--red-bright)}
  .review-msg.success{color:var(--gold)}
  .review-login-note{font-size:.6rem;color:var(--light);letter-spacing:.15em;line-height:2}
  .review-login-note a{color:var(--red);text-decoration:none}
  .review-login-note a:hover{color:var(--cream)}
  @media(max-width:900px){
    .product-wrap{grid-template-columns:1fr;min-height:auto}
    .product-image-col{min-height:55vw;max-height:70vw}
    .product-info-col{padding:2.5rem 1.5rem}
    .related-grid{grid-template-columns:repeat(2,1fr)}
  }
  @media(max-width:768px){
    .product-name{font-size:clamp(32px,8vw,52px)}
    .product-info-col{padding:2rem 1.2rem}
  }
  </style>

  <main>
    <div class="product-wrap">
      <!-- Imagen + galería -->
      <div class="product-image-col" id="imageCol">
        <div class="gallery-main" id="galleryMain">
          <div class="img-placeholder"><span>M</span></div>
          <span class="product-collection-badge" id="productCollection">—</span>
        </div>
        <div class="gallery-thumbs" id="galleryThumbs" style="display:none"></div>
      </div>
      <!-- Info -->
      <div class="product-info-col">
        <div>
          <p class="product-eyebrow" id="productEyebrow">✦ Crazy Monkey ✦</p>
          <h1 class="product-name" id="productName">Cargando...</h1>
        </div>
        <div class="product-divider"><span></span></div>
        <p class="product-desc" id="productDesc"></p>
        <p class="product-price">$95.000 COP <small>Edición limitada</small></p>
        <div id="stockBadge" style="display:none"></div>
        <!-- Tallas -->
        <div class="size-section">
          <p class="size-label">Talla</p>
          <div class="size-options">
            <button class="size-btn" onclick="selectSize(this)">XS</button>
            <button class="size-btn" onclick="selectSize(this)">S</button>
            <button class="size-btn" onclick="selectSize(this)">M</button>
            <button class="size-btn" onclick="selectSize(this)">L</button>
            <button class="size-btn" onclick="selectSize(this)">XL</button>
            <button class="size-btn" onclick="selectSize(this)">XXL</button>
          </div>
          <p class="size-note" id="sizeNote"></p>
          <button class="size-guide-toggle" onclick="openTallasModal()">Guía de tallas →</button>
        </div>
        <!-- Botón agregar -->
        <button class="add-to-cart-btn" id="addBtn" onclick="addToCart()">
          Agregar al carrito →
        </button>
        <!-- Detalles -->
        <div class="product-details">
          <div class="detail-row">
            <span class="detail-key">Material</span>
            <span class="detail-val">100% algodón ring-spun · 180 g/m²</span>
          </div>
          <div class="detail-row">
            <span class="detail-key">Impresión</span>
            <span class="detail-val">Serigrafía de alta definición</span>
          </div>
          <div class="detail-row">
            <span class="detail-key">Envío</span>
            <span class="detail-val">Nacional — 3 a 5 días hábiles</span>
          </div>
          <div class="detail-row">
            <span class="detail-key">Colección</span>
            <span class="detail-val" id="detailCollection">—</span>
          </div>
        </div>
      </div>
    </div>
  </main>

  <!-- Relacionados -->
  <section class="related-section" id="relatedSection" style="display:none">
    <p class="related-header">✦ Más de la misma colección</p>
    <div class="related-grid" id="relatedGrid"></div>
  </section>

  <!-- Reviews -->
  <section class="reviews-section" id="reviewsSection">
    <div class="reviews-header">
      <div>
        <p class="reviews-title" id="reviewsTitle">Reseñas</p>
        <div class="reviews-summary" id="reviewsSummary" style="display:none">
          <span class="reviews-avg" id="reviewsAvg">—</span>
          <div class="reviews-stars-row" id="reviewsStarsRow"></div>
          <span class="reviews-count" id="reviewsCount"></span>
        </div>
      </div>
    </div>
    <div class="reviews-list" id="reviewsList">
      <p class="reviews-empty">Cargando reseñas...</p>
    </div>
    <div id="reviewFormArea"></div>
  </section>

  <!-- Modal Guía de Tallas -->
  <div class="tallas-modal-overlay" id="tallasModal" onclick="if(event.target===this)closeTallasModal()">
    <div class="tallas-modal">
      <div class="tallas-modal-header">
        <p class="tallas-modal-title">Guía de Tallas</p>
        <button class="tallas-modal-close" onclick="closeTallasModal()">✕</button>
      </div>
      <div class="tallas-modal-body">
        <p class="tallas-eyebrow">✦ Camisetas Crazy Monkey — Corte Unisex Recto</p>
        <table class="tallas-table">
          <thead>
            <tr><th>Talla</th><th>Pecho (cm)</th><th>Largo (cm)</th><th>Hombros (cm)</th><th>Manga (cm)</th></tr>
          </thead>
          <tbody>
            <tr data-talla="XS"><td>XS</td><td>86 – 91</td><td>66</td><td>42</td><td>19</td></tr>
            <tr data-talla="S"><td>S</td><td>91 – 96</td><td>69</td><td>44</td><td>20</td></tr>
            <tr data-talla="M"><td>M</td><td>96 – 101</td><td>72</td><td>46</td><td>21</td></tr>
            <tr data-talla="L"><td>L</td><td>101 – 107</td><td>74</td><td>48</td><td>22</td></tr>
            <tr data-talla="XL"><td>XL</td><td>107 – 112</td><td>77</td><td>50</td><td>23</td></tr>
            <tr data-talla="XXL"><td>XXL</td><td>112 – 117</td><td>79</td><td>52</td><td>24</td></tr>
          </tbody>
        </table>
        <p class="tallas-measure-title">Cómo tomar las medidas</p>
        <div class="tallas-measure-list">
          <div class="tallas-measure-item">
            <span class="tallas-measure-num">1</span>
            <span class="tallas-measure-text"><strong>Pecho:</strong> Alrededor de la parte más ancha, con brazos relajados. Cinta horizontal, ajustada sin apretar.</span>
          </div>
          <div class="tallas-measure-item">
            <span class="tallas-measure-num">2</span>
            <span class="tallas-measure-text"><strong>Largo:</strong> Desde el punto más alto del hombro hasta el borde inferior de la prenda.</span>
          </div>
          <div class="tallas-measure-item">
            <span class="tallas-measure-num">3</span>
            <span class="tallas-measure-text"><strong>Hombros:</strong> De costura a costura por la parte trasera.</span>
          </div>
          <div class="tallas-measure-item">
            <span class="tallas-measure-num">4</span>
            <span class="tallas-measure-text"><strong>Manga:</strong> Desde la costura del hombro hasta el borde de la manga.</span>
          </div>
        </div>
        <div class="tallas-tip">
          <strong>¿Entre dos tallas?</strong> Elige la más grande. El corte es recto — no entallado.
        </div>
        <div class="tallas-note">
          Medidas de la prenda terminada, no del cuerpo.<br>
          ¿Dudas? Escríbenos al <strong>+57 301 656 8222</strong>.
        </div>
      </div>
    </div>
  </div>

  <script is:inline>
  var SUPABASE_URL = 'https://ljwldqgzzjhbujnmeelt.supabase.co';
  var SUPABASE_ANON_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Imxqd2xkcWd6empoYnVqbm1lZWx0Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzU1MjQzNDgsImV4cCI6MjA5MTEwMDM0OH0.HsXfcfQ0D26Yu5p4NwtxRwk0YOVg5--UTVmPUUS4LLg';

  var product = JSON.parse(localStorage.getItem('cm_current_product') || 'null');
  var selectedSize = null;
  var selectedStars = 0;
  var reviewsSession = null;

  async function initProduct() {
    if (!product) {
      var params = new URLSearchParams(location.search);
      var nombre = params.get('nombre');
      if (nombre) {
        try {
          var res = await fetch('/.netlify/functions/productos');
          var productos = await res.json();
          var found = productos.find(function(p) { return p.nombre === decodeURIComponent(nombre); });
          if (found) {
            product = { img: found.imagen, imagenes: found.imagenes || null, name: found.nombre,
              collection: found.coleccion, desc: found.descripcion, cat: found.categoria, price: found.precio,
              stock_tallas: found.stock_tallas || null };
            localStorage.setItem('cm_current_product', JSON.stringify(product));
          }
        } catch(e) {}
      }
      if (!product) { window.location.href = '/index.html'; return; }
    }

    // Actualizar título y SEO dinámicamente
    document.title = product.name + ' — CRAZY MONKEY';
    var pageUrl = 'https://crazymonkey.store/producto.html?nombre=' + encodeURIComponent(product.name);
    var desc = product.desc || 'Diseño independiente, gótico y disidente hecho en Colombia. Edición limitada.';
    var img = product.img || 'https://crazymonkey.store/og-cover.jpg';
    document.querySelector('meta[name="description"]').setAttribute('content', desc);
    document.querySelector('link[rel="canonical"]').setAttribute('href', pageUrl);
    document.querySelector('meta[property="og:url"]').setAttribute('content', pageUrl);
    document.querySelector('meta[property="og:title"]').setAttribute('content', product.name + ' — CRAZY MONKEY');
    document.querySelector('meta[property="og:description"]').setAttribute('content', desc);
    document.querySelector('meta[property="og:image"]').setAttribute('content', img);
    document.querySelector('meta[name="twitter:title"]').setAttribute('content', product.name + ' — CRAZY MONKEY');
    document.querySelector('meta[name="twitter:description"]').setAttribute('content', desc);
    document.querySelector('meta[name="twitter:image"]').setAttribute('content', img);

    // Imagen principal + galería
    var galleryMain = document.getElementById('galleryMain');
    var allImgs = [product.img].concat(Array.isArray(product.imagenes) ? product.imagenes : []).filter(Boolean);

    if (allImgs.length) {
      var mainImg = document.createElement('img');
      mainImg.src = allImgs[0];
      mainImg.alt = product.name;
      mainImg.className = 'product-img';
      mainImg.id = 'mainProductImg';
      mainImg.loading = 'eager';
      galleryMain.querySelector('.img-placeholder').replaceWith(mainImg);
    }

    // Miniaturas si hay más de 1 imagen
    if (allImgs.length > 1) {
      var thumbsEl = document.getElementById('galleryThumbs');
      thumbsEl.style.display = 'flex';
      allImgs.forEach(function(url, i) {
        var t = document.createElement('img');
        t.src = url;
        t.alt = product.name + ' ' + (i + 1);
        t.className = 'gallery-thumb' + (i === 0 ? ' active' : '');
        t.loading = 'lazy';
        t.onclick = function() {
          document.getElementById('mainProductImg').src = url;
          document.querySelectorAll('.gallery-thumb').forEach(function(th) { th.classList.remove('active'); });
          t.classList.add('active');
        };
        thumbsEl.appendChild(t);
      });
    }
    document.getElementById('productCollection').textContent = product.collection;
    document.getElementById('productName').textContent = product.name;
    document.getElementById('productDesc').textContent = product.desc;
    document.getElementById('productEyebrow').textContent = '✦ ' + product.collection + ' ✦';
    document.getElementById('detailCollection').textContent = product.collection;

    loadStockBadge(product.name);

    // Schema.org Product (rich snippets)
    var schemaEl = document.getElementById('product-schema');
    if (!schemaEl) {
      schemaEl = document.createElement('script');
      schemaEl.id = 'product-schema';
      schemaEl.type = 'application/ld+json';
      document.head.appendChild(schemaEl);
    }
    schemaEl.textContent = JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Product',
      name: product.name,
      description: desc,
      image: img,
      brand: { '@type': 'Brand', name: 'Crazy Monkey' },
      offers: {
        '@type': 'Offer',
        priceCurrency: 'COP',
        price: product.price || 95000,
        availability: 'https://schema.org/InStock',
        seller: { '@type': 'Organization', name: 'Crazy Monkey Collection Noir' }
      }
    });

    // Productos relacionados
    var allProducts = JSON.parse(localStorage.getItem('cm_catalog') || '[]');
    if (!allProducts.length) {
      try {
        var r = await fetch('/.netlify/functions/productos');
        var ps = await r.json();
        allProducts = ps.map(function(p) {
          return { img: p.imagen, name: p.nombre, collection: p.coleccion, desc: p.descripcion, cat: p.categoria, price: p.precio };
        });
        localStorage.setItem('cm_catalog', JSON.stringify(allProducts));
      } catch(e) {}
    }

    var related = allProducts.filter(function(p) {
      return p.collection === product.collection && p.name !== product.name;
    }).slice(0, 4);

    if (related.length > 0) {
      var section = document.getElementById('relatedSection');
      var grid = document.getElementById('relatedGrid');
      section.style.display = 'block';
      grid.innerHTML = related.map(function(p) {
        return '<div class="related-card" onclick=\'goToProduct(' + JSON.stringify(p).replace(/'/g, "&#39;") + ')\'>' +
          '<img src="' + p.img + '" alt="' + p.name + '" loading="lazy">' +
          '<div class="related-card-info">' +
            '<p class="related-card-name">' + p.name + '</p>' +
            '<p class="related-card-price">$' + (p.price||95000).toLocaleString('es-CO') + ' COP</p>' +
          '</div></div>';
      }).join('');
    }
  }

  function goToProduct(p) {
    localStorage.setItem('cm_current_product', JSON.stringify(p));
    window.scrollTo(0,0);
    location.reload();
  }

  async function loadStockBadge(nombre) {
    try {
      var res = await fetch('/.netlify/functions/productos');
      var productos = await res.json();
      var p = productos.find(function(pr) { return pr.nombre === nombre; });
      if (!p) return;

      var badge = document.getElementById('stockBadge');

      // ── Stock por talla ──
      if (p.stock_tallas && typeof p.stock_tallas === 'object') {
        product.stock_tallas = p.stock_tallas;
        var totalDisponible = 0;
        document.querySelectorAll('.size-btn').forEach(function(btn) {
          var talla = btn.textContent.trim();
          var datos = p.stock_tallas[talla];
          if (datos) {
            var disp = (datos.total || 0) - (datos.vendido || 0);
            totalDisponible += disp;
            if (disp <= 0) {
              btn.disabled = true;
              btn.style.opacity = '.3';
              btn.style.cursor = 'not-allowed';
              btn.title = 'Agotado';
            } else if (disp <= 2) {
              btn.style.borderColor = '#c8a84b';
              btn.title = 'Últimas ' + disp;
            }
          } else {
            // talla no configurada = no disponible
            btn.disabled = true;
            btn.style.opacity = '.2';
            btn.style.cursor = 'not-allowed';
          }
        });
        badge.style.display = 'inline-flex';
        if (totalDisponible <= 0) {
          badge.innerHTML = '<span class="stock-badge stock-agotado"><span class="stock-dot stock-dot-gray"></span>Agotado — Edición cerrada</span>';
          document.getElementById('addBtn').disabled = true;
          document.getElementById('addBtn').textContent = 'Agotado';
        } else if (totalDisponible <= 5) {
          badge.innerHTML = '<span class="stock-badge stock-pocas"><span class="stock-dot stock-dot-gold"></span>Últimas ' + totalDisponible + ' unidades</span>';
        } else {
          badge.innerHTML = '<span class="stock-badge stock-limitada"><span class="stock-dot stock-dot-red"></span>Edición limitada — stock disponible por talla</span>';
        }
        return;
      }

      // ── Stock global (legacy) ──
      if (p.stock_total === null || p.stock_total === undefined) return;
      var restante = p.stock_total - (p.stock_vendido || 0);
      badge.style.display = 'inline-flex';

      if (restante <= 0) {
        badge.innerHTML = '<span class="stock-badge stock-agotado"><span class="stock-dot stock-dot-gray"></span>Agotado — Edición cerrada</span>';
        var addBtn = document.getElementById('addBtn');
        addBtn.disabled = true;
        addBtn.textContent = 'Agotado';
        document.querySelectorAll('.size-btn').forEach(function(b) {
          b.disabled = true;
          b.style.opacity = '.3';
          b.style.cursor = 'not-allowed';
        });
      } else if (restante <= 5) {
        badge.innerHTML = '<span class="stock-badge stock-pocas"><span class="stock-dot stock-dot-gold"></span>Últimas ' + restante + ' unidades</span>';
      } else if (restante <= 15) {
        badge.innerHTML = '<span class="stock-badge stock-limitada"><span class="stock-dot stock-dot-red"></span>' + restante + ' unidades disponibles</span>';
      } else {
        badge.innerHTML = '<span class="stock-badge stock-limitada"><span class="stock-dot stock-dot-red"></span>Edición limitada · ' + p.stock_total + ' unidades</span>';
      }
    } catch(e) {
      console.error('Stock badge error:', e);
    }
  }

  function selectSize(btn) {
    document.querySelectorAll('.size-btn').forEach(function(b) { b.classList.remove('selected'); });
    btn.classList.add('selected');
    selectedSize = btn.textContent;
    document.getElementById('sizeNote').textContent = '';
    highlightTalla(selectedSize);
  }

  function openTallasModal() {
    document.getElementById('tallasModal').classList.add('open');
    document.body.style.overflow = 'hidden';
    if (selectedSize) highlightTalla(selectedSize);
  }

  function closeTallasModal() {
    document.getElementById('tallasModal').classList.remove('open');
    document.body.style.overflow = '';
  }

  function highlightTalla(talla) {
    document.querySelectorAll('.tallas-table tbody tr').forEach(function(row) {
      row.classList.toggle('tallas-highlight', row.dataset.talla === talla);
    });
  }

  // addToCart uses cart/saveCart/updateCartUI from CartPanel
  function addToCart() {
    if (!selectedSize) {
      document.getElementById('sizeNote').textContent = '← Selecciona una talla primero';
      return;
    }
    if (!product) return;

    cart.push({
      img: product.img,
      name: product.name,
      collection: product.collection,
      desc: product.desc,
      size: selectedSize,
      id: Date.now(),
      price: 95000,
    });
    saveCart();
    updateCartUI();

    var btn = document.getElementById('addBtn');
    btn.textContent = '¡Agregado! ✦';
    btn.classList.add('added');
    setTimeout(function() {
      btn.textContent = 'Agregar al carrito →';
      btn.classList.remove('added');
    }, 1800);

    var cartBtn = document.querySelector('.cart-btn');
    cartBtn.classList.add('cart-added-flash');
    setTimeout(function() { cartBtn.classList.remove('cart-added-flash'); }, 600);

    toggleCart();
  }

  // checkout() is called by CartPanel's checkoutFn="checkout"
  async function checkout() {
    if (!cart.length) return;
    var btn = document.getElementById('checkoutBtn');
    var note = document.querySelector('.cart-checkout-note');
    btn.disabled = true;
    btn.textContent = 'Generando pago...';
    if (note) note.textContent = 'Conectando con MercadoPago...';
    try {
      var res = await fetch('/.netlify/functions/create-preference', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ items: cart }),
      });
      if (!res.ok) throw new Error();
      var data = await res.json();
      window.location.href = data.init_point;
    } catch(e) {
      btn.disabled = false;
      btn.textContent = 'Pagar con MercadoPago →';
      if (note) { note.textContent = 'Error al conectar. Intenta por WhatsApp ↓'; note.style.color = 'var(--red-bright)'; }
    }
  }

  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') { closeCart(); closeTallasModal(); }
  });

  // ── REVIEWS ──
  function starsHTML(n, size) {
    return [1,2,3,4,5].map(function(i) {
      return '<span class="star ' + (i <= n ? 'filled' : '') + '" style="font-size:' + (size==='lg'?'1rem':'.75rem') + '">★</span>';
    }).join('');
  }

  async function loadReviews() {
    if (!product) return;
    try {
      var res = await fetch('/.netlify/functions/reviews?producto=' + encodeURIComponent(product.name));
      var data = await res.json();
      var reviews = data.reviews, avg = data.avg, total = data.total;

      if (total > 0) {
        document.getElementById('reviewsTitle').textContent = 'Reseñas (' + total + ')';
        document.getElementById('reviewsAvg').textContent = avg;
        document.getElementById('reviewsStarsRow').innerHTML = starsHTML(Math.round(avg), 'lg');
        document.getElementById('reviewsCount').textContent = total + ' reseña' + (total !== 1 ? 's' : '');
        document.getElementById('reviewsSummary').style.display = 'flex';
      }

      var listEl = document.getElementById('reviewsList');
      if (reviews.length === 0) {
        listEl.innerHTML = '<p class="reviews-empty">Sé el primero en dejar una reseña.</p>';
      } else {
        listEl.innerHTML = reviews.map(function(r) {
          var date = new Date(r.created_at).toLocaleDateString('es-CO', { day: '2-digit', month: 'short', year: 'numeric' });
          return '<div class="review-card">' +
            '<div class="review-card-top">' +
              '<span class="review-autor">' + (r.nombre || 'Anónimo') + '</span>' +
              '<span class="review-date">' + date + '</span>' +
            '</div>' +
            '<div class="review-stars">' + starsHTML(r.estrellas) + '</div>' +
            '<p class="review-comentario">' + r.comentario + '</p>' +
          '</div>';
        }).join('');
      }
    } catch(e) {
      document.getElementById('reviewsList').innerHTML = '<p class="reviews-empty">Error cargando reseñas.</p>';
    }
    await renderReviewForm();
  }

  async function renderReviewForm() {
    var formArea = document.getElementById('reviewFormArea');
    if (!product) return;
    var session = null;
    try {
      var sb = supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY);
      var result = await sb.auth.getSession();
      session = result.data.session;
      reviewsSession = session;
    } catch(e) {}

    if (!session) {
      formArea.innerHTML =
        '<div class="review-form-wrap">' +
          '<p class="review-form-title">¿Ya la tienes?</p>' +
          '<p class="review-login-note">' +
            '<a href="/cuenta.html">Inicia sesión</a> para dejar tu reseña.<br>' +
            'Solo quienes han comprado este diseño pueden reseñarlo.' +
          '</p>' +
        '</div>';
      return;
    }

    formArea.innerHTML =
      '<div class="review-form-wrap">' +
        '<p class="review-form-title">Deja tu reseña</p>' +
        '<div class="star-picker" id="starPicker">' +
          [1,2,3,4,5].map(function(i) {
            return '<button class="star-pick" onclick="pickStar(' + i + ')" data-star="' + i + '">★</button>';
          }).join('') +
        '</div>' +
        '<textarea class="review-input" id="reviewComentario" rows="3" placeholder="¿Qué te pareció la calidad, el diseño, el ajuste?"></textarea>' +
        '<button class="review-submit" id="reviewSubmitBtn" onclick="submitReview()">Publicar reseña →</button>' +
        '<p class="review-msg" id="reviewMsg"></p>' +
      '</div>';
  }

  function pickStar(n) {
    selectedStars = n;
    document.querySelectorAll('.star-pick').forEach(function(btn) {
      btn.classList.toggle('active', parseInt(btn.dataset.star) <= n);
    });
  }

  async function submitReview() {
    var comentario = document.getElementById('reviewComentario').value.trim();
    var msgEl = document.getElementById('reviewMsg');
    var btn = document.getElementById('reviewSubmitBtn');
    msgEl.textContent = '';
    msgEl.className = 'review-msg';

    if (selectedStars === 0) {
      msgEl.textContent = '✕ Selecciona una puntuación.';
      msgEl.classList.add('error');
      return;
    }
    if (comentario.length < 10) {
      msgEl.textContent = '✕ El comentario debe tener al menos 10 caracteres.';
      msgEl.classList.add('error');
      return;
    }

    btn.disabled = true;
    btn.textContent = 'Publicando...';

    try {
      var res = await fetch('/.netlify/functions/reviews', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Authorization': 'Bearer ' + reviewsSession.access_token,
        },
        body: JSON.stringify({ producto: product.name, estrellas: selectedStars, comentario: comentario }),
      });
      var data = await res.json();
      if (!res.ok) {
        msgEl.textContent = '✕ ' + data.error;
        msgEl.classList.add('error');
        btn.disabled = false;
        btn.textContent = 'Publicar reseña →';
        return;
      }
      msgEl.textContent = '✔ Reseña enviada. Aparecerá luego de ser revisada. ¡Gracias!';
      msgEl.classList.add('success');
      btn.textContent = 'Enviada ✔';
      document.getElementById('reviewComentario').disabled = true;
    } catch(e) {
      msgEl.textContent = '✕ Error de conexión. Intenta de nuevo.';
      msgEl.classList.add('error');
      btn.disabled = false;
      btn.textContent = 'Publicar reseña →';
    }
  }

  initProduct();
  window.addEventListener('load', function() { if (product) loadReviews(); });
  </script>
</LayoutPublic>
