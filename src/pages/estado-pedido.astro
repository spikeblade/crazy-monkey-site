---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Estado de tu Pedido — CRAZY MONKEY" noindex={true}>
  <style is:global>
  body{min-height:100vh}
  nav{position:fixed;top:0;left:0;right:0;z-index:1000;display:flex;justify-content:space-between;align-items:center;padding:1.2rem 2.5rem;background:rgba(8,8,8,0.98)}
  .nav-back{font-size:.5rem;letter-spacing:.25em;color:var(--light);text-decoration:none;text-transform:uppercase;transition:color .2s}
  .nav-back:hover{color:var(--cream)}
  :root{--green:#4a9a5a}
  .hero{padding:9rem 2rem 4rem;text-align:center;position:relative;z-index:1}
  .hero-eyebrow{font-size:.55rem;letter-spacing:.5em;color:var(--red);text-transform:uppercase;margin-bottom:1rem}
  .hero-title{font-family:'UnifrakturMaguntia',cursive;font-size:clamp(38px,7vw,80px);line-height:.95;color:var(--white);text-shadow:0 0 60px rgba(176,26,26,.35);margin-bottom:.8rem}
  .hero-sub{font-family:'Bebas Neue',sans-serif;font-size:clamp(11px,1.8vw,18px);letter-spacing:.4em;color:var(--gold);margin-bottom:2rem}
  .hero-divider{display:flex;align-items:center;gap:1rem;justify-content:center;margin-bottom:3rem}
  .hero-divider span{display:block;width:50px;height:1px;background:linear-gradient(90deg,transparent,var(--red))}
  .hero-divider span:last-child{background:linear-gradient(90deg,var(--red),transparent)}
  .hero-divider em{font-size:.5rem;color:var(--light);letter-spacing:.3em;font-style:normal}
  .search-wrap{max-width:460px;margin:0 auto;position:relative;z-index:1}
  .search-card{border:1px solid #1e1e1e;border-left:3px solid var(--red);background:rgba(176,26,26,.03);padding:2.5rem}
  .search-label{font-size:.5rem;letter-spacing:.4em;color:var(--light);text-transform:uppercase;display:block;margin-bottom:.5rem}
  .search-input{width:100%;background:#111;border:1px solid #2a2a2a;border-bottom:1px solid var(--red);color:var(--cream);font-family:'Space Mono',monospace;font-size:.8rem;padding:.8rem 1rem;outline:none;transition:border-color .2s}
  .search-input:focus{border-color:var(--cream);background:#161616}
  .search-input::placeholder{color:#444}
  .search-btn{width:100%;margin-top:1rem;font-family:'Bebas Neue',sans-serif;font-size:1rem;letter-spacing:.3em;color:var(--black);background:var(--red);border:none;padding:.9rem 2rem;cursor:pointer;clip-path:polygon(8px 0%,100% 0%,calc(100% - 8px) 100%,0% 100%);transition:background .2s,transform .2s}
  .search-btn:hover{background:var(--cream);transform:translateY(-2px)}
  .search-btn:disabled{background:#2a2a2a;color:#555;cursor:not-allowed;transform:none}
  .search-note{font-size:.55rem;color:var(--light);margin-top:1rem;line-height:1.8;text-align:center}
  .search-error{font-size:.6rem;color:#c94a4a;margin-top:.8rem;text-align:center;min-height:1rem}
  #results{max-width:680px;margin:3rem auto;padding:0 2rem;position:relative;z-index:1}
  .empty-state{text-align:center;padding:3rem 0;font-size:.65rem;color:var(--light);line-height:2}
  .empty-state strong{color:var(--cream);display:block;font-size:.8rem;margin-bottom:.5rem}
  .order-card{border:1px solid #1e1e1e;background:var(--deep);margin-bottom:2rem;overflow:hidden}
  .order-header{display:flex;justify-content:space-between;align-items:flex-start;padding:1.5rem 1.8rem;border-bottom:1px solid #1a1a1a;gap:1rem;flex-wrap:wrap}
  .order-date{font-size:.5rem;letter-spacing:.3em;color:var(--light);text-transform:uppercase;margin-bottom:.3rem}
  .order-name{font-family:'Bebas Neue',sans-serif;font-size:1.1rem;letter-spacing:.1em;color:var(--white)}
  .order-id{font-size:.45rem;color:#3a3a3a;margin-top:.2rem;word-break:break-all}
  .order-status-badge{font-size:.5rem;letter-spacing:.3em;text-transform:uppercase;padding:.4rem .9rem;border:1px solid currentColor;white-space:nowrap;align-self:flex-start}
  .timeline{padding:1.5rem 1.8rem;border-bottom:1px solid #1a1a1a}
  .timeline-track{display:flex;align-items:center;gap:0;margin-bottom:1rem}
  .timeline-step{flex:1;display:flex;flex-direction:column;align-items:center;position:relative}
  .timeline-step:not(:last-child)::after{content:'';position:absolute;top:8px;left:50%;width:100%;height:1px;background:#2a2a2a;z-index:0}
  .timeline-step.done:not(:last-child)::after{background:var(--red)}
  .timeline-dot{width:16px;height:16px;border-radius:50%;border:2px solid #2a2a2a;background:var(--black);position:relative;z-index:1;flex-shrink:0}
  .timeline-step.done .timeline-dot{border-color:var(--red);background:var(--red)}
  .timeline-step.current .timeline-dot{border-color:var(--gold);background:var(--gold);box-shadow:0 0 8px rgba(200,168,75,.4)}
  .timeline-step.success .timeline-dot{border-color:var(--green);background:var(--green)}
  .timeline-label{font-size:.38rem;letter-spacing:.2em;color:var(--light);text-transform:uppercase;margin-top:.5rem;text-align:center;line-height:1.4}
  .timeline-step.done .timeline-label,.timeline-step.current .timeline-label{color:var(--cream)}
  .order-items{padding:1.5rem 1.8rem;border-bottom:1px solid #1a1a1a}
  .items-tag{font-size:.45rem;letter-spacing:.4em;color:var(--red);text-transform:uppercase;margin-bottom:1rem}
  .item-row{display:flex;justify-content:space-between;align-items:baseline;gap:1rem;padding:.6rem 0;border-bottom:1px solid #141414;font-size:.65rem}
  .item-row:last-child{border-bottom:none}
  .item-name{color:var(--cream);flex:1}
  .item-size{font-size:.5rem;color:var(--light);display:block;letter-spacing:.2em;margin-top:.15rem}
  .item-price{color:var(--gold);white-space:nowrap;font-size:.7rem}
  .order-total-row{display:flex;justify-content:space-between;padding:1rem 1.8rem;font-family:'Bebas Neue',sans-serif;letter-spacing:.1em}
  .order-total-label{font-size:.8rem;color:var(--light)}
  .order-total-val{font-size:1.1rem;color:var(--white)}
  .tracking-block{padding:1.2rem 1.8rem;background:rgba(74,154,90,.04);border-top:1px solid rgba(74,154,90,.15)}
  .tracking-tag{font-size:.45rem;letter-spacing:.4em;color:var(--green);text-transform:uppercase;margin-bottom:.5rem}
  .tracking-num{font-size:.75rem;color:var(--cream);word-break:break-all}
  .tracking-link{display:inline-block;margin-top:.7rem;font-size:.5rem;letter-spacing:.3em;color:var(--black);background:var(--green);padding:.5rem 1.2rem;text-decoration:none;text-transform:uppercase;transition:opacity .2s}
  .tracking-link:hover{opacity:.85}
  .footer-note{text-align:center;padding:1rem 2rem 4rem;font-size:.55rem;color:#444;line-height:2;position:relative;z-index:1}
  .footer-note a{color:#555;text-decoration:none}
  .footer-note a:hover{color:var(--light)}
  .fade-in{animation:fadeUp .5s ease both}
  @media(max-width:600px){nav{padding:1rem 1.5rem}.search-card{padding:1.5rem}.order-header{flex-direction:column}.timeline-label{font-size:.32rem}#results{padding:0 1rem}}
  </style>

<nav>
  <a href="/index.html" class="nav-logo">Crazy<span>M</span>onkey</a>
  <a href="/index.html" class="nav-back">← Tienda</a>
</nav>

<section class="hero">
  <p class="hero-eyebrow">✦ Seguimiento ✦</p>
  <h1 class="hero-title">Estado de<br>tu Pedido</h1>
  <p class="hero-sub">Consulta en tiempo real</p>
  <div class="hero-divider"><span></span><em>Ingresa tu email de compra</em><span></span></div>

  <div class="search-wrap">
    <div class="search-card">
      <label class="search-label" for="emailInput">✦ Tu email de compra</label>
      <input type="email" id="emailInput" class="search-input" placeholder="tucorreo@ejemplo.com" autocomplete="email" inputmode="email" />
      <div class="search-error" id="searchError"></div>
      <button class="search-btn" id="searchBtn" onclick="buscarPedidos()">Consultar mis pedidos</button>
      <p class="search-note">
        Solo se muestran pedidos asociados a este email.<br>
        ¿Dudas? <a href="https://wa.me/573016568222" style="color:var(--light)">Escríbenos por WhatsApp</a>
      </p>
    </div>
  </div>
</section>

<section id="results"></section>

<footer class="footer-note">
  Crazy Monkey Collection Noir · Medellín, Colombia<br>
  <a href="https://wa.me/573016568222">WhatsApp: +57 301 656 8222</a>
</footer>

<script is:inline>
var STEPS = [
  { key: 'pago',       label: 'Pago\nrecibido' },
  { key: 'confirmado', label: 'Pedido\nconfirmado' },
  { key: 'produccion', label: 'En\nproducción' },
  { key: 'enviado',    label: 'Enviado' },
  { key: 'entregado',  label: 'Entregado' },
];

function stepIndexForOrder(step) {
  if (step <= 1) return 0;
  if (step === 2) return 1;
  if (step === 3) return 2;
  if (step === 4) return 3;
  return 4;
}

function renderTimeline(currentStep, isSuccess) {
  var stepIdx = stepIndexForOrder(currentStep);
  return '<div class="timeline"><div class="timeline-track">' +
    STEPS.map(function(s, i) {
      var cls = '';
      if (i < stepIdx) cls = 'done';
      else if (i === stepIdx) cls = isSuccess ? 'success' : 'current';
      return '<div class="timeline-step ' + cls + '">' +
        '<div class="timeline-dot"></div>' +
        '<span class="timeline-label">' + s.label.replace('\n','<br>') + '</span>' +
        '</div>';
    }).join('') +
    '</div></div>';
}

function escHtml(str) {
  return String(str == null ? '' : str)
    .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;').replace(/'/g, '&#x27;');
}

function renderOrder(order) {
  var fecha = new Date(order.created_at).toLocaleDateString('es-CO', { year: 'numeric', month: 'long', day: 'numeric' });
  var isSuccess = order.estado.step >= 4;
  var isRejected = order.estado.step === 0;

  var items = order.items.map(function(item) {
    return '<div class="item-row"><div class="item-name">' + escHtml(item.name || item.nombre || '') +
      '<span class="item-size">Talla ' + escHtml(String(item.size || item.talla || '')) + '</span></div>' +
      '<span class="item-price">$' + Number(item.price || item.precio || 0).toLocaleString('es-CO') + '</span></div>';
  }).join('');

  var trackingHtml = order.tracking_number ? (
    '<div class="tracking-block"><p class="tracking-tag">✦ Información de envío</p>' +
    '<p class="tracking-num">' + escHtml(order.carrier ? order.carrier.toUpperCase() : '') + ' · Guía: ' + escHtml(order.tracking_number) + '</p>' +
    (order.tracking_url ? '<a href="' + escHtml(order.tracking_url) + '" target="_blank" rel="noopener" class="tracking-link">Rastrear envío →</a>' : '') +
    '</div>'
  ) : '';

  return '<div class="order-card fade-in">' +
    '<div class="order-header"><div class="order-header-left">' +
      '<p class="order-date">' + escHtml(fecha) + '</p>' +
      '<p class="order-name">' + escHtml(order.nombre) + '</p>' +
      '<p class="order-id">ID: ' + escHtml(order.id) + '</p>' +
    '</div><span class="order-status-badge" style="color:' + escHtml(order.estado.color) + ';border-color:' + escHtml(order.estado.color) + '">' +
      escHtml(order.estado.label) + '</span></div>' +
    (isRejected ? '' : renderTimeline(order.estado.step, isSuccess)) +
    '<div class="order-items"><p class="items-tag">✦ Productos</p>' + items + '</div>' +
    '<div class="order-total-row"><span class="order-total-label">Total</span><span class="order-total-val">$' + Number(order.total).toLocaleString('es-CO') + ' COP</span></div>' +
    trackingHtml +
    '</div>';
}

async function buscarPedidos() {
  var emailInput = document.getElementById('emailInput');
  var errorEl = document.getElementById('searchError');
  var btn = document.getElementById('searchBtn');
  var results = document.getElementById('results');

  errorEl.textContent = '';
  var email = emailInput.value.trim().toLowerCase();

  if (!email || !email.includes('@')) { errorEl.textContent = 'Ingresa un email válido.'; return; }

  btn.disabled = true;
  btn.textContent = 'Consultando...';
  results.innerHTML = '';

  try {
    var res = await fetch('/.netlify/functions/get-order-status', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ email: email }),
    });
    var data = await res.json();

    if (!res.ok) { errorEl.textContent = data.error || 'Error al consultar. Intenta de nuevo.'; return; }

    if (!data.orders || data.orders.length === 0) {
      results.innerHTML = '<div class="empty-state fade-in"><strong>No encontramos pedidos</strong>No hay pedidos asociados a <em>' + escHtml(email) + '</em>.<br>Verifica que el email sea el mismo que usaste al comprar.<br><br><a href="https://wa.me/573016568222" style="color:var(--light)">¿Necesitas ayuda? Escríbenos →</a></div>';
      return;
    }
    results.innerHTML = data.orders.map(renderOrder).join('');
  } catch(e) {
    errorEl.textContent = 'Error de conexión. Intenta de nuevo.';
  } finally {
    btn.disabled = false;
    btn.textContent = 'Consultar mis pedidos';
  }
}

document.getElementById('emailInput').addEventListener('keydown', function(e) {
  if (e.key === 'Enter') buscarPedidos();
});
</script>
</Layout>
