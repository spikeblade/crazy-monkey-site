  document.getElementById('loteModal').addEventListener('click', function(e) { if (e.target === this) closeLoteModal(); });

  // ═══════════════════════════════════════════════════════
  // CATÁLOGO (taxonomias)
  // ═══════════════════════════════════════════════════════
  let _taxonomias = { categorias: [], colecciones: [] };

  async function loadTaxonomias() {
    const results = await Promise.all([
      fetch('/.netlify/functions/taxonomias?tipo=colecciones').then(function(r) { return r.json(); }).catch(function() { return []; }),
      fetch('/.netlify/functions/taxonomias?tipo=categorias').then(function(r) { return r.json(); }).catch(function() { return []; }),
    ]);
    _taxonomias.colecciones = Array.isArray(results[0]) ? results[0] : [];
    _taxonomias.categorias = Array.isArray(results[1]) ? results[1] : [];
    return _taxonomias;
  }

  function renderTaxonomiaSelect(selectId, items, currentValue, valueKey, labelKey) {
    valueKey = valueKey || 'nombre'; labelKey = labelKey || 'nombre';
    const sel = document.getElementById(selectId);
    if (!sel) return;
    sel.innerHTML = items.map(function(item) {
      return `<option value="${item[valueKey]}"${item[valueKey] === currentValue ? ' selected' : ''}>${item[labelKey]}</option>`;
    }).join('');
    if (!currentValue && items.length) sel.value = items[0][valueKey];
  }

  function renderCatalogoList(tipo) {
    const items = _taxonomias[tipo];
    const listEl = document.getElementById(tipo + 'List');
    if (!listEl) return;
    if (!items.length) { listEl.innerHTML = `<p style="font-size:.55rem;color:#444;padding:.4rem">Sin ${tipo} aún.</p>`; return; }
    listEl.innerHTML = items.map(function(item) {
      return `<div class="cat-item ${tipo === 'colecciones' && item.activo === false ? 'cat-item-inactive' : ''}">
        <span class="cat-item-name">${item.nombre}${tipo === 'categorias' ? `<span class="cat-item-slug">${item.slug}</span>` : ''}</span>
        ${tipo === 'colecciones' ? `<button class="cat-btn" onclick="toggleColeccion('${item.id}',${!item.activo})">${item.activo ? '●' : '○'}</button>` : ''}
        <button class="cat-btn danger" onclick="eliminarTaxonomia('${tipo}','${item.id}','${item.nombre.replace(/'/g,"\\'") }')">✕</button>
      </div>`;
    }).join('');
  }

  async function crearTaxonomia(tipo) {
    const inputId = tipo === 'colecciones' ? 'newColeccionNombre' : 'newCategoriaNombre';
    const msgId = tipo === 'colecciones' ? 'coleccionesMsg' : 'categoriasMsg';
    const nombre = document.getElementById(inputId).value.trim();
    const msgEl = document.getElementById(msgId);
    if (!nombre) { msgEl.textContent = 'Ingresa un nombre.'; return; }
    msgEl.textContent = '';
    const res = await fetch('/.netlify/functions/taxonomias', {
      method: 'POST',
      headers: authH({ 'Content-Type': 'application/json' }),
      body: JSON.stringify({ tipo, nombre }),
    });
    if (!res.ok) { const err = await res.json().catch(function() { return {}; }); msgEl.textContent = err.error || 'Error al crear.'; return; }
    document.getElementById(inputId).value = '';
    await loadTaxonomias(); renderCatalogoList(tipo);
  }

  async function eliminarTaxonomia(tipo, id, nombre) {
    if (!confirm(`¿Eliminar "${nombre}"?`)) return;
    await fetch(`/.netlify/functions/taxonomias?tipo=${tipo}&id=${id}`, { method: 'DELETE', headers: authH() });
    await loadTaxonomias(); renderCatalogoList(tipo);
  }

  async function toggleColeccion(id, nuevoActivo) {
    await fetch(`/.netlify/functions/taxonomias?tipo=colecciones&id=${id}`, {
      method: 'PATCH',
      headers: authH({ 'Content-Type': 'application/json' }),
      body: JSON.stringify({ activo: nuevoActivo }),
    });
    await loadTaxonomias(); renderCatalogoList('colecciones');
  }

  // ═══════════════════════════════════════════════════════
  // CLIENTES
  // ═══════════════════════════════════════════════════════
  async function loadClientes() {
    const tbody = document.getElementById('clientesBody');
    const countEl = document.getElementById('clientesCount');
    tbody.innerHTML = '<tr><td colspan="5" class="loading">Cargando clientes...</td></tr>';
    try {
      const res = await fetch('/.netlify/functions/get-clientes', { headers: authH() });
      if (!res.ok) throw new Error('Error ' + res.status);
      const clientes = await res.json();
      if (countEl) countEl.textContent = clientes.length + ' clientes';
      if (!clientes.length) {
        tbody.innerHTML = '<tr><td colspan="5" style="font-size:.6rem;color:#444;letter-spacing:.2em;padding:1.5rem 1rem">Sin clientes aún.</td></tr>';
        return;
      }
      tbody.innerHTML = clientes.map(function(c) {
        const fecha = c.ultimo_pedido
          ? new Date(c.ultimo_pedido).toLocaleDateString('es-CO', { day: '2-digit', month: 'short', year: 'numeric' })
          : '—';
        const estados = Object.entries(c.estados || {})
          .map(function(e) { return `<span class="estado-badge ${e[0]}">${e[0]}</span>`; }).join(' ');
        return `<tr>
          <td>
            <div class="order-name">${c.nombre}</div>
            <div class="order-tel">${c.email || '—'}</div>
            <div class="order-tel">${c.telefono || ''}</div>
          </td>
          <td class="order-location">${c.ciudad ? c.ciudad + (c.departamento ? ', ' + c.departamento : '') : '—'}</td>
          <td style="font-family:'Space Mono',monospace;font-size:.7rem;color:var(--cream);text-align:center">${c.total_pedidos}</td>
          <td class="order-total">$${(c.total_gastado || 0).toLocaleString('es-CO')}</td>
          <td>
            <div class="order-date">${fecha}</div>
            <div style="margin-top:.3rem">${estados}</div>
          </td>
        </tr>`;
      }).join('');
    } catch(e) {
      tbody.innerHTML = '<tr><td colspan="5" style="font-size:.6rem;color:var(--red);padding:1rem">Error cargando clientes.</td></tr>';
    }
  }

  // ═══════════════════════════════════════════════════════
  // PRODUCTOS ADMIN
  // ═══════════════════════════════════════════════════════
  let allProductos = [];
  let editingId = null;
  let _galeriaUrls = [];

  async function loadProductosAdmin() {
    const grid = document.getElementById('prodGrid');
    try {
      const res = await fetch('/.netlify/functions/productos', { headers: authH() });
      allProductos = await res.json();
      if (!allProductos.length) { grid.innerHTML = '<p style="font-size:.6rem;color:#444;letter-spacing:.2em">No hay productos.</p>'; return; }
      grid.innerHTML = allProductos.map(function(p) {
        let stockHtml = '<p class="stock-info">Sin límite de stock</p>';
        if (p.stock_tallas && typeof p.stock_tallas === 'object') {
          const entries = Object.entries(p.stock_tallas);
          const totalDisp = entries.reduce(function(acc, e) { return acc + Math.max(0, (e[1].total||0) - (e[1].vendido||0)); }, 0);
          const totalUnits = entries.reduce(function(acc, e) { return acc + (e[1].total||0); }, 0);
          const pct = totalUnits > 0 ? Math.max(0, Math.min(100, (totalDisp / totalUnits) * 100)) : 0;
          const barClass = pct > 50 ? 'stock-bar-green' : pct > 20 ? 'stock-bar-gold' : 'stock-bar-red';
          const infoClass = pct > 50 ? '' : pct > 20 ? 'warning' : 'danger';
          const tallasBadges = entries.map(function(e) {
            const disp = (e[1].total||0) - (e[1].vendido||0);
            const col = disp <= 0 ? '#444' : disp <= 2 ? '#c8a84b' : '#4a9a4a';
            return `<span style="font-size:.45rem;color:${col};margin-right:.3rem">${e[0]}:${disp}</span>`;
          }).join('');
          stockHtml = `<div class="stock-bar-wrap"><div class="stock-bar ${barClass}" style="width:${pct}%"></div></div><p class="stock-info ${infoClass}">${tallasBadges}</p>`;
        } else if (p.stock_total) {
          const restante = p.stock_total - (p.stock_vendido || 0);
          const pct = Math.max(0, Math.min(100, (restante / p.stock_total) * 100));
          const barClass = pct > 50 ? 'stock-bar-green' : pct > 20 ? 'stock-bar-gold' : 'stock-bar-red';
          const infoClass = pct > 50 ? '' : pct > 20 ? 'warning' : 'danger';
          const label = restante <= 0 ? 'Agotado' : `${restante} de ${p.stock_total} disponibles`;
          stockHtml = `<div class="stock-bar-wrap"><div class="stock-bar ${barClass}" style="width:${pct}%"></div></div><p class="stock-info ${infoClass}">${label}</p>`;
        }
        return `<div class="prod-card ${p.activo ? '' : 'inactive'}" id="prodcard-${p.id}">
          <span class="prod-status ${p.activo ? 'active' : 'inactive'}">${p.activo ? 'Activo' : 'Inactivo'}</span>
          <img class="prod-card-img" src="${p.imagen}" alt="${p.nombre}" onerror="this.style.background='#1a1a1a';this.style.minHeight='80px'">
          <p class="prod-card-col">${p.coleccion}</p>
          <p class="prod-card-name">${p.nombre}</p>
          ${stockHtml}
          <div class="prod-card-actions">
            <button class="prod-action-btn" onclick="openProductoModal('${p.id}')">✎ Editar</button>
            <button class="prod-action-btn ${p.activo ? 'toggle-on' : 'toggle-off'}" onclick="toggleProducto('${p.id}',${!p.activo})">${p.activo ? '● Activo' : '○ Inactivo'}</button>
            <button class="prod-action-btn danger" onclick="deleteProducto('${p.id}','${p.nombre.replace(/'/g,"\\'")}')">✕ Eliminar</button>
          </div>
        </div>`;
      }).join('');
    } catch(e) { grid.innerHTML = '<p style="font-size:.6rem;color:var(--red)">Error cargando productos.</p>'; }
  }

  async function toggleProducto(id, nuevoEstado) {
    await fetch('/.netlify/functions/productos', {
      method: 'PATCH',
      headers: authH({ 'Content-Type': 'application/json' }),
      body: JSON.stringify({ id, activo: nuevoEstado }),
    });
    loadProductosAdmin();
  }

  async function deleteProducto(id, nombre) {
    if (!confirm(`¿Eliminar "${nombre}"? Esta acción no se puede deshacer.`)) return;
    await fetch(`/.netlify/functions/productos?id=${id}`, { method: 'DELETE', headers: authH() });
    loadProductosAdmin();
  }

  // ─── Upload de imágenes ───────────────────────────────────

  async function uploadImagen(file) {
    return new Promise(function(resolve, reject) {
      var reader = new FileReader();
      reader.onload = async function(e) {
        var base64 = e.target.result.split(',')[1];
        try {
          var res = await fetch('/.netlify/functions/upload-imagen', {
            method: 'POST',
            headers: authH({ 'Content-Type': 'application/json' }),
            body: JSON.stringify({ filename: file.name, content: base64, contentType: file.type }),
          });
          var result = await res.json();
          if (!res.ok) { reject(new Error(result.error || 'Error subiendo imagen')); return; }
          resolve(result.url);
        } catch(err) { reject(err); }
      };
      reader.onerror = reject;
      reader.readAsDataURL(file);
    });
  }

  async function uploadArte(file) {
    return new Promise(function(resolve, reject) {
      var reader = new FileReader();
      reader.onload = async function(e) {
        var base64 = e.target.result.split(',')[1];
        try {
          var res = await fetch('/.netlify/functions/upload-imagen', {
            method: 'POST',
            headers: authH({ 'Content-Type': 'application/json' }),
            body: JSON.stringify({ filename: file.name, content: base64, contentType: file.type, bucket: 'artes' }),
          });
          var result = await res.json();
          if (!res.ok) { reject(new Error(result.error || 'Error subiendo archivo')); return; }
          resolve(result.url);
        } catch(err) { reject(err); }
      };
      reader.onerror = reject;
      reader.readAsDataURL(file);
    });
  }

  function setArteStatus(hiddenId, statusId, linkId, url) {
    var statusEl = document.getElementById(statusId);
    var linkEl = document.getElementById(linkId);
    document.getElementById(hiddenId).value = url || '';
    if (url) {
      var filename = url.split('/').pop().replace(/^\d+_/, '');
      var label = filename.length > 38 ? filename.substring(0, 35) + '...' : filename;
      statusEl.textContent = '✔ ' + label;
      statusEl.className = 'arte-status-text ok';
      linkEl.href = url;
      linkEl.style.display = 'inline';
    } else {
      statusEl.textContent = 'sin archivo';
      statusEl.className = 'arte-status-text';
      linkEl.style.display = 'none';
    }
  }

  async function handleArteUpload(hiddenId, statusId, linkId, file) {
    if (!file) return;
    var statusEl = document.getElementById(statusId);
    statusEl.textContent = 'Subiendo...';
    statusEl.className = 'arte-status-text uploading';
    document.getElementById(linkId).style.display = 'none';
    try {
      var url = await uploadArte(file);
      setArteStatus(hiddenId, statusId, linkId, url);
    } catch(err) {
      statusEl.textContent = '✕ ' + err.message;
      statusEl.className = 'arte-status-text error';
    }
  }

  function setImagenPreview(url) {
    var preview = document.getElementById('previewImagen');
    var placeholder = document.getElementById('imagenPlaceholder');
    var spinner = document.getElementById('imagenSpinner');
    if (url) {
      preview.src = url;
      preview.style.display = 'block';
      placeholder.style.display = 'none';
      spinner.style.display = 'none';
    } else {
      preview.src = '';
      preview.style.display = 'none';
      spinner.style.display = 'none';
      placeholder.style.display = 'block';
      placeholder.textContent = '+ Subir imagen principal';
    }
  }

  async function handleImagenPrincipal(file) {
    if (!file) return;
    var placeholder = document.getElementById('imagenPlaceholder');
    var spinner = document.getElementById('imagenSpinner');
    var preview = document.getElementById('previewImagen');
    placeholder.style.display = 'none';
    preview.style.display = 'none';
    spinner.style.display = 'block';
    try {
      var url = await uploadImagen(file);
      document.getElementById('mImagen').value = url;
      setImagenPreview(url);
    } catch(err) {
      spinner.style.display = 'none';
      placeholder.style.display = 'block';
      placeholder.textContent = '✕ ' + err.message;
    }
  }

  function handleDropImagen(e) {
    e.preventDefault();
    document.getElementById('imagenZone').classList.remove('dragover');
    var file = e.dataTransfer.files[0];
    if (file && file.type.startsWith('image/')) handleImagenPrincipal(file);
  }

  async function handleGaleria(files) {
    for (var i = 0; i < files.length; i++) {
      var idx = _galeriaUrls.length;
      _galeriaUrls.push(null);
      renderGaleriaStrip();
      try {
        var url = await uploadImagen(files[i]);
        _galeriaUrls[idx] = url;
      } catch(err) {
        _galeriaUrls.splice(idx, 1);
      }
      renderGaleriaStrip();
    }
    document.getElementById('fileGaleria').value = '';
  }

  function removeGaleriaImg(idx) {
    _galeriaUrls.splice(idx, 1);
    renderGaleriaStrip();
  }

  function renderGaleriaStrip() {
    var strip = document.getElementById('galeriaStrip');
    if (!strip) return;
    strip.innerHTML = _galeriaUrls.map(function(url, i) {
      if (!url) {
        return '<div class="galeria-thumb"><div class="galeria-thumb-spinner">subiendo...</div></div>';
      }
      return '<div class="galeria-thumb">'
        + '<img src="' + url + '" alt="Galería ' + (i + 1) + '">'
        + '<button class="galeria-thumb-remove" onclick="removeGaleriaImg(' + i + ')" title="Quitar">×</button>'
        + '</div>';
    }).join('');
  }

  // ─────────────────────────────────────────────────────────

  async function openProductoModal(id) {
    editingId = id;
    const msgEl = document.getElementById('modalMsg');
    msgEl.textContent = ''; msgEl.className = 'modal-msg';
    if (!_taxonomias.colecciones.length || !_taxonomias.categorias.length) await loadTaxonomias();
    if (id) {
      const p = allProductos.find(function(pr) { return pr.id === id; });
      if (!p) return;
      document.getElementById('modalTitle').textContent = 'Editar Producto';
      document.getElementById('modalId').value = p.id;
      document.getElementById('mNombre').value = p.nombre;
      renderTaxonomiaSelect('mColeccion', _taxonomias.colecciones, p.coleccion, 'nombre', 'nombre');
      renderTaxonomiaSelect('mCategoria', _taxonomias.categorias, p.categoria, 'slug', 'nombre');
      document.getElementById('mDescripcion').value = p.descripcion;
      document.getElementById('mImagen').value = p.imagen;
      setImagenPreview(p.imagen);
      _galeriaUrls = Array.isArray(p.imagenes) ? p.imagenes.slice() : [];
      renderGaleriaStrip();
      setArteStatus('mArteUrl', 'arteUrlStatus', 'arteUrlLink', p.arte_url || '');
      setArteStatus('mEtiquetaUrl', 'etiquetaUrlStatus', 'etiquetaUrlLink', p.etiqueta_url || '');
      document.getElementById('mPrecio').value = p.precio;
      document.getElementById('mOrden').value = p.orden;
      document.getElementById('mActivo').checked = p.activo;
      document.getElementById('mStock').value = (p.stock_total !== null && p.stock_total !== undefined) ? p.stock_total : '';
      // Stock por talla → "XS:5, S:10, M:15, ..."
      if (p.stock_tallas && typeof p.stock_tallas === 'object') {
        document.getElementById('mStockTallas').value = Object.entries(p.stock_tallas)
          .map(function(e) { return e[0] + ':' + (e[1].total || 0); }).join(', ');
      } else {
        document.getElementById('mStockTallas').value = '';
      }
    } else {
      document.getElementById('modalTitle').textContent = 'Nuevo Producto';
      document.getElementById('modalId').value = '';
      document.getElementById('mNombre').value = '';
      renderTaxonomiaSelect('mColeccion', _taxonomias.colecciones, '', 'nombre', 'nombre');
      renderTaxonomiaSelect('mCategoria', _taxonomias.categorias, '', 'slug', 'nombre');
      document.getElementById('mDescripcion').value = '';
      document.getElementById('mImagen').value = '';
      setImagenPreview('');
      _galeriaUrls = [];
      renderGaleriaStrip();
      setArteStatus('mArteUrl', 'arteUrlStatus', 'arteUrlLink', '');
      setArteStatus('mEtiquetaUrl', 'etiquetaUrlStatus', 'etiquetaUrlLink', '');
      document.getElementById('mStockTallas').value = '';
      document.getElementById('mPrecio').value = '95000';
      document.getElementById('mOrden').value = '99';
      document.getElementById('mActivo').checked = true;
      document.getElementById('mStock').value = '';
    }
    document.getElementById('prodModal').classList.add('open');
  }

  function closeProdModal() {
    document.getElementById('prodModal').classList.remove('open');
    editingId = null;
    _galeriaUrls = [];
    setImagenPreview('');
    setArteStatus('mArteUrl', 'arteUrlStatus', 'arteUrlLink', '');
    setArteStatus('mEtiquetaUrl', 'etiquetaUrlStatus', 'etiquetaUrlLink', '');
  }

  async function saveProducto() {
    const msgEl = document.getElementById('modalMsg');
    msgEl.textContent = '';
    const nombre = document.getElementById('mNombre').value.trim();
    const descripcion = document.getElementById('mDescripcion').value.trim();
    const imagen = document.getElementById('mImagen').value.trim();
    if (!nombre || !descripcion || !imagen) { msgEl.textContent = '✕ Nombre, descripción e imagen son obligatorios.'; msgEl.className = 'modal-msg error'; return; }
    const stockVal = document.getElementById('mStock').value;

    const imagenes = _galeriaUrls.filter(Boolean).length ? _galeriaUrls.filter(Boolean) : null;

    // Parsear stock por talla ("XS:5, S:10, M:15" → {XS:{total:5,vendido:0},...})
    const stockTallasRaw = document.getElementById('mStockTallas').value.trim();
    let stock_tallas = null;
    if (stockTallasRaw) {
      stock_tallas = {};
      stockTallasRaw.split(',').forEach(function(part) {
        const pair = part.trim().split(':');
        if (pair.length === 2) {
          const talla = pair[0].trim().toUpperCase();
          const total = parseInt(pair[1]) || 0;
          stock_tallas[talla] = { total, vendido: 0 };
        }
      });
      if (!Object.keys(stock_tallas).length) stock_tallas = null;
    }

    const data = {
      nombre, coleccion: document.getElementById('mColeccion').value,
      categoria: document.getElementById('mCategoria').value, descripcion, imagen,
      arte_url: document.getElementById('mArteUrl').value.trim() || null,
      etiqueta_url: document.getElementById('mEtiquetaUrl').value.trim() || null,
      imagenes: imagenes && imagenes.length ? imagenes : null,
      stock_tallas,
      precio: parseInt(document.getElementById('mPrecio').value) || 95000,
      orden: parseInt(document.getElementById('mOrden').value) || 99,
      activo: document.getElementById('mActivo').checked,
      stock_total: stockVal !== '' ? parseInt(stockVal) : null,
    };
    if (editingId) data.id = editingId;
    const res = await fetch('/.netlify/functions/productos', {
      method: editingId ? 'PATCH' : 'POST',
      headers: authH({ 'Content-Type': 'application/json' }),
      body: JSON.stringify(data),
    });
    const result = await res.json();
    if (!res.ok || !result.success) { msgEl.textContent = `✕ ${result.error || 'Error guardando producto.'}`; msgEl.className = 'modal-msg error'; return; }
    msgEl.textContent = '✔ Guardado correctamente.'; msgEl.className = 'modal-msg success';
    setTimeout(function() { closeProdModal(); loadProductosAdmin(); }, 800);
  }

  document.getElementById('prodModal').addEventListener('click', function(e) { if (e.target === this) closeProdModal(); });

  // ═══════════════════════════════════════════════════════
  // ANALYTICS
  // ═══════════════════════════════════════════════════════
  function fmt(n) { return Math.round(n).toLocaleString('es-CO'); }
  function fmtM(n) {
    if (n >= 1000000) return '$' + (n / 1000000).toFixed(1) + 'M';
    if (n >= 1000) return '$' + (n / 1000).toFixed(0) + 'K';
    return '$' + fmt(n);
  }
  function deltaHtml(pct) {
    if (pct === null || pct === undefined) return '<span class="an-delta neutral">— sin datos anteriores</span>';
    const cls = pct >= 0 ? 'up' : 'down';
    const arrow = pct >= 0 ? '▲' : '▼';
    return `<span class="an-delta ${cls}">${arrow} ${Math.abs(pct)}% vs mes anterior</span>`;
  }
  function renderBarChart(semanas) {
    const maxIngresos = Math.max(...semanas.map(function(s) { return s.ingresos; }), 1);
    return `<div class="an-chart">${semanas.map(function(s) {
      const pct = Math.round((s.ingresos / maxIngresos) * 100);
      const tip = `${s.label}: $${fmt(s.ingresos)} COP · ${s.pedidos} pedido${s.pedidos !== 1 ? 's' : ''}`;
      return `<div class="an-bar-wrap"><div class="an-bar" style="height:${pct}%" title="${tip}"></div><span class="an-bar-label">${s.label}</span></div>`;
    }).join('')}</div>`;
  }
  function renderHBars(items, nameKey, valKey, color) {
    color = color || '';
    const max = Math.max(...items.map(function(i) { return i[valKey]; }), 1);
    return `<div class="an-hbar-wrap">${items.map(function(item) {
      return `<div class="an-hbar-row"><span class="an-hbar-name" title="${item[nameKey]}">${item[nameKey]}</span><div class="an-hbar-track"><div class="an-hbar-fill ${color}" style="width:${Math.round((item[valKey]/max)*100)}%"></div></div><span class="an-hbar-val">${item[valKey]}</span></div>`;
    }).join('')}</div>`;
  }
  function renderEstados(por_estado) {
    const labels = { confirmado:'Confirmado', en_produccion:'En producción', listo:'Listo', enviado:'Enviado', entregado:'Entregado' };
    return `<div class="an-estado-grid">${Object.entries(labels).map(function(e) {
      return `<div class="an-estado-chip"><div class="an-estado-chip-num">${por_estado[e[0]]||0}</div><div class="an-estado-chip-label">${e[1]}</div></div>`;
    }).join('')}</div>`;
  }
  function renderAnalytics(data) {
    const r = data.resumen;
    document.getElementById('analyticsContent').innerHTML = `
      <div class="an-grid">
        <div class="an-card"><div class="an-card-accent"></div><div class="an-num">${fmtM(r.ingresos_total)}</div><div class="an-label">Ingresos totales (COP)</div></div>
        <div class="an-card gold"><div class="an-card-accent"></div><div class="an-num">${fmtM(r.ingresos_mes)}</div><div class="an-label">Este mes</div>${deltaHtml(r.variacion_ingresos)}</div>
        <div class="an-card"><div class="an-card-accent"></div><div class="an-num">${r.pedidos_total}</div><div class="an-label">Pedidos confirmados</div></div>
        <div class="an-card"><div class="an-card-accent"></div><div class="an-num small">${r.pedidos_mes}</div><div class="an-label">Pedidos este mes</div>${deltaHtml(r.variacion_pedidos)}</div>
        <div class="an-card green"><div class="an-card-accent"></div><div class="an-num small">${fmtM(r.ticket_promedio)}</div><div class="an-label">Ticket promedio</div></div>
      </div>
      <div class="an-section"><p class="an-section-title">✦ Ingresos — últimas 8 semanas</p>${renderBarChart(data.por_semana)}</div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:2rem;margin-bottom:2rem">
        <div class="an-section"><p class="an-section-title">✦ Productos más vendidos</p>${data.top_productos.length?renderHBars(data.top_productos,'nombre','unidades'):'<p style="font-size:.55rem;color:#444">Sin datos.</p>'}</div>
        <div class="an-section"><p class="an-section-title">✦ Top departamentos</p>${data.top_departamentos.length?renderHBars(data.top_departamentos,'departamento','pedidos','gold'):'<p style="font-size:.55rem;color:#444">Sin datos.</p>'}</div>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:2rem">
        <div class="an-section"><p class="an-section-title">✦ Tallas más vendidas</p>${data.tallas.length?renderHBars(data.tallas,'talla','cantidad','green'):'<p style="font-size:.55rem;color:#444">Sin datos.</p>'}</div>
        <div class="an-section"><p class="an-section-title">✦ Estado de pedidos (aprobados)</p>${renderEstados(data.por_estado)}</div>
      </div>`;
  }
  async function _loadAnalytics() {
    document.getElementById('analyticsContent').innerHTML = '<p style="font-size:.6rem;color:#444;letter-spacing:.2em">Cargando datos...</p>';
    try {
      const res = await fetch('/.netlify/functions/analytics', { headers: authH() });
      if (!res.ok) throw new Error('Error ' + res.status);
      renderAnalytics(await res.json());
    } catch(e) { document.getElementById('analyticsContent').innerHTML = `<p style="font-size:.6rem;color:var(--red)">Error: ${e.message}</p>`; }
  }

  // ═══════════════════════════════════════════════════════
  // REVIEWS ADMIN
  // ═══════════════════════════════════════════════════════
  async function loadAdminReviews() {
    const tbody = document.getElementById('reviewsAdminBody');
    try {
      const res = await fetch('/.netlify/functions/reviews', { headers: authH() });
      const data = await res.json();
      const reviews = data.reviews || [];
      if (!reviews.length) { tbody.innerHTML = '<tr><td colspan="6" class="empty-state">No hay reseñas todavía</td></tr>'; return; }
      tbody.innerHTML = reviews.map(function(r) {
        const date = new Date(r.created_at).toLocaleDateString('es-CO', { day:'2-digit', month:'short', year:'numeric' });
        const stars = '★'.repeat(r.estrellas) + '☆'.repeat(5 - r.estrellas);
        const badge = r.aprobada
          ? '<span style="color:#4a9a5a;font-size:.5rem;letter-spacing:.15em">✔ APROBADA</span>'
          : '<span style="color:#c8a84b;font-size:.5rem;letter-spacing:.15em">⏳ PENDIENTE</span>';
        const actions = r.aprobada
          ? `<button onclick="reviewAction('${r.id}',false)" style="font-family:monospace;font-size:.5rem;color:#c94a4a;background:none;border:1px solid #2a1a1a;padding:.25rem .5rem;cursor:pointer;margin-top:.3rem">Rechazar</button>
             <button onclick="reviewDelete('${r.id}')" style="font-family:monospace;font-size:.5rem;color:#555;background:none;border:1px solid #1a1a1a;padding:.25rem .5rem;cursor:pointer;margin-top:.3rem">Eliminar</button>`
          : `<button onclick="reviewAction('${r.id}',true)" style="font-family:monospace;font-size:.5rem;color:#4a9a5a;background:none;border:1px solid #1a2a1a;padding:.25rem .5rem;cursor:pointer;margin-top:.3rem">Aprobar</button>
             <button onclick="reviewDelete('${r.id}')" style="font-family:monospace;font-size:.5rem;color:#555;background:none;border:1px solid #1a1a1a;padding:.25rem .5rem;cursor:pointer;margin-top:.3rem">Eliminar</button>`;
        return `<tr>
          <td style="color:var(--white);font-size:.7rem">${r.producto}</td>
          <td style="color:var(--light);font-size:.65rem">${r.nombre||'—'}</td>
          <td style="color:var(--gold);letter-spacing:.1em">${stars}</td>
          <td style="color:var(--cream);font-size:.65rem;max-width:300px">${r.comentario}</td>
          <td class="order-date">${date}</td>
          <td style="min-width:100px"><div style="display:flex;flex-direction:column;gap:.2rem">${badge}${actions}</div></td>
        </tr>`;
      }).join('');
    } catch(e) { tbody.innerHTML = '<tr><td colspan="6" class="empty-state">Error cargando reseñas</td></tr>'; }
  }

  async function reviewAction(id, aprobada) {
    await fetch(`/.netlify/functions/reviews?id=${id}`, {
      method: 'PATCH', headers: authH({ 'Content-Type': 'application/json' }), body: JSON.stringify({ aprobada }),
    });
    loadAdminReviews();
  }

  async function reviewDelete(id) {
    if (!confirm('¿Eliminar esta reseña?')) return;
    await fetch(`/.netlify/functions/reviews?id=${id}`, { method: 'DELETE', headers: authH() });
    loadAdminReviews();
  }

  // ═══════════════════════════════════════════════════════
  // INIT — auto-login si hay sesión en sessionStorage
  // ═══════════════════════════════════════════════════════
  (async function init() {
    const session = getSession();
    if (!session) return;
    try {
      const res = await fetch('/.netlify/functions/get-orders', { headers: authH() });
      if (!res.ok) { clearSession(); return; }
      allOrders = await res.json();
      showAdminPanel();
    } catch { showAdminPanel(); }
  })();
  </script>
</Layout>
