        <thead>
          <tr><th>Cliente</th><th>Ciudad</th><th>Pedidos</th><th>Total gastado</th><th>Último pedido</th></tr>
        </thead>
        <tbody id="clientesBody">
          <tr><td colspan="5" class="loading">Cargando clientes...</td></tr>
        </tbody>
      </table>
    </div>
  </div>

  <script is:inline>
  // ═══════════════════════════════════════════════════════
  // SESIÓN
  // ═══════════════════════════════════════════════════════
  const SESSION_KEY = 'cm_admin_v1';
  const SESSION_TTL = 8 * 60 * 60 * 1000;
  const WARN_AT = 10 * 60 * 1000;

  function saveSession(password) {
    sessionStorage.setItem(SESSION_KEY, JSON.stringify({ password, expiresAt: Date.now() + SESSION_TTL }));
  }
  function getSession() {
    try {
      const raw = sessionStorage.getItem(SESSION_KEY);
      if (!raw) return null;
      const s = JSON.parse(raw);
      if (Date.now() >= s.expiresAt) { sessionStorage.removeItem(SESSION_KEY); return null; }
      return s;
    } catch { return null; }
  }
  function clearSession() { sessionStorage.removeItem(SESSION_KEY); }
  function getPassword() { return (getSession() || {}).password || ''; }
  function authH(extra) { return Object.assign({ 'x-admin-password': getPassword() }, extra || {}); }
  function renovarSesion() { const s = getSession(); if (s) { saveSession(s.password); updateSessionTimer(); } }

  let _timerInterval = null;
  function startSessionTimer() { updateSessionTimer(); _timerInterval = setInterval(updateSessionTimer, 30000); }
  function updateSessionTimer() {
    const s = getSession();
    const el = document.getElementById('sessionTimer');
    const btnRenovar = document.getElementById('refreshSessionBtn');
    if (!el) return;
    if (!s) { doLogout(); return; }
    const remaining = s.expiresAt - Date.now();
    const totalMins = Math.floor(remaining / 60000);
    const hrs = Math.floor(totalMins / 60);
    const mins = totalMins % 60;
    el.className = '';
    btnRenovar.style.display = 'none';
    if (remaining < 5 * 60000) {
      el.textContent = `⚠ Sesión expira en ${totalMins}m`;
      el.className = 'session-critical';
      btnRenovar.style.display = 'inline-block';
    } else if (remaining < WARN_AT) {
      el.textContent = `Sesión: ${mins}m restantes`;
      el.className = 'session-warn';
      btnRenovar.style.display = 'inline-block';
    } else {
      el.textContent = hrs > 0 ? `Sesión: ${hrs}h ${mins}m` : `Sesión: ${mins}m`;
    }
  }

  // ═══════════════════════════════════════════════════════
  // NAVEGACIÓN SPA (hash routing)
  // ═══════════════════════════════════════════════════════
  let allOrders = [];
  let currentFilter = 'todos';
  let _currentSection = 'pedidos';

  const PANELS = {
    pedidos: '.orders-wrap',
    reviews: '#reviewsPanel',
    productos: '#productosPanel',
    produccion: '#produccionPanel',
    configuracion: '#configuracionPanel',
    catalogo: '#catalogoPanel',
    analytics: '#analyticsPanel',
    clientes: '#clientesPanel',
  };

  function hidePanels() {
    Object.values(PANELS).forEach(function(sel) {
      const el = document.querySelector(sel);
      if (el) el.style.display = 'none';
    });
  }

  function navigate(section, filter) {
    _currentSection = section;
    const hash = filter && section === 'pedidos' ? `${section}/${filter}` : section;
    history.pushState({ section, filter }, '', `#${hash}`);
    document.querySelectorAll('#mainNav .filter-btn').forEach(function(btn) {
      const sMatch = btn.dataset.section === section;
      const fMatch = !btn.dataset.filter || btn.dataset.filter === (filter || 'todos');
      btn.classList.toggle('active', sMatch && fMatch);
    });
    hidePanels();
    switch (section) {
      case 'pedidos':
        currentFilter = filter || 'todos';
        document.querySelector('.orders-wrap').style.display = 'block';
        renderOrders(); break;
      case 'reviews':
        document.getElementById('reviewsPanel').style.display = 'block';
        loadAdminReviews(); break;
      case 'productos':
        document.getElementById('productosPanel').style.display = 'block';
        loadProductosAdmin(); break;
      case 'produccion':
        document.getElementById('produccionPanel').style.display = 'block';
        loadProduccionSummary(); loadLotes(); break;
      case 'configuracion':
        document.getElementById('configuracionPanel').style.display = 'block';
        loadConfiguracion(); break;
      case 'catalogo':
        document.getElementById('catalogoPanel').style.display = 'block';
        loadTaxonomias().then(function() { renderCatalogoList('colecciones'); renderCatalogoList('categorias'); }); break;
      case 'analytics':
        document.getElementById('analyticsPanel').style.display = 'block';
        _loadAnalytics(); break;
      case 'clientes':
        document.getElementById('clientesPanel').style.display = 'block';
        loadClientes(); break;
    }
  }

  function recargarVista() { if (_currentSection === 'pedidos') loadOrders(); else navigate(_currentSection); }

  window.addEventListener('popstate', function(e) {
    const state = e.state || {};
    navigate(state.section || 'pedidos', state.filter);
  });

  function resolveHashOnLoad() {
    const hash = location.hash.slice(1);
    if (!hash) return navigate('pedidos', 'todos');
    const parts = hash.split('/');
    if (PANELS[parts[0]]) navigate(parts[0], parts[1]);
    else navigate('pedidos', 'todos');
  }

  // ═══════════════════════════════════════════════════════
  // AUTH
  // ═══════════════════════════════════════════════════════
  async function doLogin() {
    const pass = document.getElementById('passInput').value.trim();
    if (!pass) return;
    const res = await fetch('/.netlify/functions/get-orders', {
      headers: { 'x-admin-password': pass },
    }).catch(function() { return null; });
    if (!res || res.status === 401) {
      document.getElementById('loginError').textContent = '✕ Contraseña incorrecta.'; return;
    }
    if (!res.ok) {
      document.getElementById('loginError').textContent = '✕ Error de conexión. Intenta de nuevo.'; return;
    }
    saveSession(pass);
    allOrders = await res.json();
    showAdminPanel();
  }

  function doLogout() {
    clearSession();
    clearInterval(_timerInterval);
    allOrders = [];
    document.getElementById('loginScreen').style.display = 'flex';
    document.getElementById('adminPanel').style.display = 'none';
    document.getElementById('passInput').value = '';
    document.getElementById('loginError').textContent = '';
  }

  function showAdminPanel() {
    document.getElementById('loginScreen').style.display = 'none';
    document.getElementById('adminPanel').style.display = 'block';
    updateStats();
    startSessionTimer();
    resolveHashOnLoad();
  }

  let _prevOrderCount = -1;

  async function loadOrders() {
    try {
      const res = await fetch('/.netlify/functions/get-orders', { headers: authH() });
      if (res.status === 401) { doLogout(); return; }
      if (!res.ok) throw new Error('Server error');
      const newOrders = await res.json();
      // Notificar si llegaron pedidos nuevos después de la carga inicial
      if (_prevOrderCount >= 0 && newOrders.length > _prevOrderCount) {
        const diff = newOrders.length - _prevOrderCount;
        showNewOrderToast(diff);
      }
      _prevOrderCount = newOrders.length;
      allOrders = newOrders;
      updateStats();
      if (_currentSection === 'pedidos') renderOrders();
    } catch(err) { console.error('loadOrders error:', err); }
  }

  function showNewOrderToast(count) {
    const toast = document.getElementById('newOrderToast');
    toast.textContent = count === 1 ? '🛍 Nuevo pedido recibido' : `🛍 ${count} nuevos pedidos`;
    toast.style.display = 'block';
    // Beep con AudioContext
    try {
      const ctx = new (window.AudioContext || window.webkitAudioContext)();
      const osc = ctx.createOscillator();
      const gain = ctx.createGain();
      osc.connect(gain); gain.connect(ctx.destination);
      osc.frequency.value = 880; gain.gain.value = 0.3;
      osc.start(); osc.stop(ctx.currentTime + 0.15);
    } catch(e) {}
    setTimeout(function() { toast.style.display = 'none'; }, 5000);
  }

  function updateStats() {
    document.getElementById('statTotal').textContent = allOrders.length;
    document.getElementById('statPendientes').textContent =
      allOrders.filter(function(o) { return o.estado === 'pendiente' || o.estado === 'confirmado'; }).length;
    document.getElementById('statEnviados').textContent =
      allOrders.filter(function(o) { return o.estado === 'enviado'; }).length;
    const revenue = allOrders
      .filter(function(o) { return o.estado !== 'pendiente'; })
      .reduce(function(s, o) { return s + (o.total || 0); }, 0);
    document.getElementById('statRevenue').textContent = '$' + revenue.toLocaleString('es-CO');
  }

  function renderOrders() {
    const q = (document.getElementById('searchOrdersInput')?.value || '').toLowerCase().trim();
    let filtered = currentFilter === 'todos'
      ? allOrders
      : allOrders.filter(function(o) { return o.estado === currentFilter; });
    if (q) {
      filtered = filtered.filter(function(o) {
        return (o.nombre || '').toLowerCase().includes(q) ||
               (o.email || '').toLowerCase().includes(q) ||
               (o.telefono || '').toLowerCase().includes(q);
      });
    }
    const tbody = document.getElementById('ordersBody');
    if (filtered.length === 0) {
      tbody.innerHTML = '<tr><td colspan="8" class="empty-state">No hay pedidos' + (q ? ' que coincidan con "' + q + '"' : ' en esta categoría') + '</td></tr>';
      return;
    }
    tbody.innerHTML = filtered.map(function(order) {
      const date = new Date(order.created_at);
      const dateStr = date.toLocaleDateString('es-CO', { day:'2-digit', month:'short', year:'numeric' });
      const timeStr = date.toLocaleTimeString('es-CO', { hour:'2-digit', minute:'2-digit' });
      const items = Array.isArray(order.items) ? order.items : [];
      const itemsHtml = items.map(function(i) {
        return `<p class="order-item-line">${i.name}<span>T.${i.size}</span></p>`;
      }).join('');
      const waMsg = encodeURIComponent(
        `Hola ${order.nombre}! Tu pedido de Crazy Monkey está en camino 🖤\n` +
        `Productos: ${items.map(function(i) { return i.name + ' T.' + i.size; }).join(', ')}\n` +
        `Total: $${(order.total||0).toLocaleString('es-CO')} COP`
      );
      const waTel = (order.telefono || '').replace(/\D/g, '');
      const esOversell = order.estado === 'revisar_stock';
      return `<tr${esOversell ? ' style="background:rgba(201,74,74,.04)"' : ''}>
        <td>
          ${esOversell ? '<div class="revisar-stock-banner">⚠ Revisar stock</div>' : ''}
          <p class="order-name">${order.nombre || '—'}</p>
          <p class="order-tel">${order.telefono || '—'}</p>
        </td>
        <td><p class="order-location">${order.ciudad || '—'}</p><p class="order-location">${order.departamento || '—'}</p></td>
        <td><div class="order-items-list">${itemsHtml || '—'}</div></td>
        <td class="order-total">$${(order.total||0).toLocaleString('es-CO')}</td>
        <td class="order-date">${dateStr}<br>${timeStr}</td>
        <td>${esOversell
          ? `<p class="estado-revisar_stock" style="font-size:.55rem;letter-spacing:.15em;margin-bottom:.5rem">⚠ REVISAR STOCK</p>
             <button onclick="resolverOversell('${order.id}','confirmado')" style="display:block;width:100%;font-family:monospace;font-size:.5rem;letter-spacing:.1em;color:#4a9a4a;background:none;border:1px solid #1a2a1a;padding:.3rem .5rem;cursor:pointer;margin-bottom:.3rem;text-transform:uppercase">✔ Confirmar (stock repuesto)</button>
             <button onclick="resolverOversell('${order.id}','pendiente')" style="display:block;width:100%;font-family:monospace;font-size:.5rem;letter-spacing:.1em;color:#c8a84b;background:none;border:1px solid #2a2010;padding:.3rem .5rem;cursor:pointer;text-transform:uppercase">↩ Pendiente (reembolso)</button>`
          : `<select class="status-select estado-${order.estado}" onchange="updateEstado('${order.id}',this.value,this)">
               <option value="pendiente" ${order.estado==='pendiente'?'selected':''}>Pendiente</option>
               <option value="confirmado" ${order.estado==='confirmado'?'selected':''}>Confirmado</option>
               <option value="enviado" ${order.estado==='enviado'?'selected':''}>Enviado</option>
               <option value="entregado" ${order.estado==='entregado'?'selected':''}>Entregado</option>
             </select>`
        }</td>
        <td>${order.tracking_number
          ? `<span class="tracking-badge">✓ ${(order.carrier||'').toUpperCase()}</span><span class="tracking-num-cell">${order.tracking_number}</span><button class="btn-tracking" style="margin-top:.3rem" onclick="openTrackingModal('${order.id}','${order.carrier||''}','${order.tracking_number}')">✎ Editar</button>`
          : `<button class="btn-tracking" onclick="openTrackingModal('${order.id}','','')">+ Agregar guía</button>`
        }</td>
        <td>${waTel ? `<a class="wa-btn" href="https://wa.me/57${waTel}?text=${waMsg}" target="_blank">WA →</a>` : '—'}</td>
      </tr>`;
    }).join('');
  }

  async function updateEstado(id, estado, selectEl) {
    selectEl.className = `status-select estado-${estado}`;
    try {
      const res = await fetch('/.netlify/functions/get-orders', {
        method: 'PATCH',
        headers: authH({ 'Content-Type': 'application/json' }),
        body: JSON.stringify({ id, estado }),
      });
      if (!res.ok) throw new Error();
      const order = allOrders.find(function(o) { return o.id === id; });
      if (order) order.estado = estado;
      updateStats();
    } catch { alert('Error actualizando estado. Recarga la página.'); }
  }

  async function resolverOversell(id, nuevoEstado) {
    const label = nuevoEstado === 'confirmado' ? 'confirmar el pedido (stock repuesto)' : 'marcar como pendiente (reembolso)';
    if (!confirm(`¿${label}?`)) return;
    try {
      const res = await fetch('/.netlify/functions/get-orders', {
        method: 'PATCH',
        headers: authH({ 'Content-Type': 'application/json' }),
        body: JSON.stringify({ id, estado: nuevoEstado }),
      });
      if (!res.ok) throw new Error();
      const order = allOrders.find(function(o) { return o.id === id; });
      if (order) order.estado = nuevoEstado;
      renderOrders(); updateStats();
    } catch { alert('Error actualizando el pedido. Recarga la página.'); }
  }

  // ═══════════════════════════════════════════════════════
  // TRACKING
  // ═══════════════════════════════════════════════════════
  function openTrackingModal(orderId, carrier, trackingNumber) {
    document.getElementById('trackingOrderId').value = orderId;
    document.getElementById('trackingCarrier').value = carrier || 'servientrega';
    document.getElementById('trackingNumber').value = trackingNumber || '';
    document.getElementById('trackingMsg').textContent = '';
    document.getElementById('trackingMsg').className = 'modal-msg';
    document.getElementById('trackingModal').classList.add('open');
    setTimeout(function() { document.getElementById('trackingNumber').focus(); }, 100);
  }

  function closeTrackingModal() {
    document.getElementById('trackingModal').classList.remove('open');
  }

  async function saveTracking() {
    const id = document.getElementById('trackingOrderId').value;
    const carrier = document.getElementById('trackingCarrier').value;
    const tracking_number = document.getElementById('trackingNumber').value.trim();
    const msgEl = document.getElementById('trackingMsg');
    if (!tracking_number) { msgEl.textContent = '✕ Ingresa el número de guía.'; msgEl.className = 'modal-msg error'; return; }
    msgEl.textContent = 'Guardando...'; msgEl.className = 'modal-msg';
    try {
      const res = await fetch('/.netlify/functions/get-orders', {
        method: 'PATCH',
        headers: authH({ 'Content-Type': 'application/json' }),
        body: JSON.stringify({ id, tracking_number, carrier }),
      });
      if (!res.ok) throw new Error();
      const order = allOrders.find(function(o) { return o.id === id; });
      if (order) { order.tracking_number = tracking_number; order.carrier = carrier; }
      msgEl.textContent = '✔ Guía guardada. Se notificó al cliente por email.';
      msgEl.className = 'modal-msg success';
      renderOrders();
      setTimeout(closeTrackingModal, 1200);
    } catch { msgEl.textContent = '✕ Error guardando. Intenta de nuevo.'; msgEl.className = 'modal-msg error'; }
  }

  document.getElementById('trackingModal').addEventListener('click', function(e) { if (e.target === this) closeTrackingModal(); });

  // Auto-refresh cada 2 minutos
  setInterval(function() { if (getSession()) loadOrders(); }, 120000);

  // ═══════════════════════════════════════════════════════
  // CONFIGURACIÓN
  // ═══════════════════════════════════════════════════════
  async function loadConfiguracion() {
    try {
      const res = await fetch('/.netlify/functions/configuracion');
      const cfg = await res.json();
      document.getElementById('cfgPrecio').value = cfg.precio_venta || 95000;
      document.getElementById('cfgCosto').value = cfg.costo_produccion || 49000;
      updateMargenPreview();
    } catch(e) { console.error('Config load error:', e); }
  }

  function updateMargenPreview() {
    const precio = parseInt(document.getElementById('cfgPrecio').value) || 0;
    const costo = parseInt(document.getElementById('cfgCosto').value) || 0;
    if (!precio || !costo) return;
    const margen = precio - costo;
    const pct = precio > 0 ? Math.round((margen / precio) * 100) : 0;
    const preview = document.getElementById('cfgMargenPreview');
    preview.style.display = 'block';
    document.getElementById('cfgPreviewPrecio').textContent = '$' + precio.toLocaleString('es-CO') + ' COP';
    document.getElementById('cfgPreviewCosto').textContent = '$' + costo.toLocaleString('es-CO') + ' COP';
    const margenEl = document.getElementById('cfgPreviewMargen');
    margenEl.textContent = '$' + margen.toLocaleString('es-CO') + ' COP (' + pct + '%)';
    margenEl.style.color = margen >= 0 ? '#4a9a4a' : 'var(--red)';
  }

  async function saveConfiguracion() {
    const precio = parseInt(document.getElementById('cfgPrecio').value);
    const costo = parseInt(document.getElementById('cfgCosto').value);
    const msgEl = document.getElementById('cfgMsg');
    msgEl.textContent = ''; msgEl.className = 'modal-msg';
    if (!precio || !costo) { msgEl.textContent = '✕ Ambos valores son obligatorios.'; msgEl.className = 'modal-msg error'; return; }
    if (precio < costo) { msgEl.textContent = '✕ El precio de venta no puede ser menor al costo.'; msgEl.className = 'modal-msg error'; return; }
    const res = await fetch('/.netlify/functions/configuracion', {
      method: 'PATCH',
      headers: authH({ 'Content-Type': 'application/json' }),
      body: JSON.stringify({ precio_venta: precio, costo_produccion: costo }),
    });
    const data = await res.json();
    if (!res.ok || !data.success) { msgEl.textContent = '✕ ' + (data.error || 'Error guardando.'); msgEl.className = 'modal-msg error'; return; }
    msgEl.textContent = '✔ Configuración guardada. Los cambios aplican a nuevos pedidos.'; msgEl.className = 'modal-msg success';
  }

  // ═══════════════════════════════════════════════════════
  // PRODUCCIÓN
  // ═══════════════════════════════════════════════════════
  async function loadProduccionSummary() {
    try {
      const res = await fetch('/.netlify/functions/produccion?action=summary', { headers: authH() });
      const data = await res.json();
      const { designs, totalUnidades, totalIngresos, totalCosto, margen, pedidosCount } = data;
      document.getElementById('summaryCards').innerHTML = `
        <div class="summary-card"><p class="summary-card-num">${pedidosCount}</p><p class="summary-card-label">Pedidos confirmados</p></div>
        <div class="summary-card"><p class="summary-card-num">${totalUnidades}</p><p class="summary-card-label">Unidades a producir</p></div>
        <div class="summary-card"><p class="summary-card-num gold">$${totalIngresos.toLocaleString('es-CO')}</p><p class="summary-card-label">Ingresos confirmados</p></div>
        <div class="summary-card"><p class="summary-card-num red">$${totalCosto.toLocaleString('es-CO')}</p><p class="summary-card-label">Costo de producción</p></div>
        <div class="summary-card"><p class="summary-card-num ${margen >= 0 ? 'green' : 'red'}">$${margen.toLocaleString('es-CO')}</p><p class="summary-card-label">Margen bruto</p></div>
        <div class="summary-card"><p class="summary-card-num ${margen >= 0 ? 'green' : 'red'}">${totalIngresos > 0 ? Math.round((margen/totalIngresos)*100) : 0}%</p><p class="summary-card-label">Margen %</p></div>`;
      if (designs.length > 0) {
        const tbody = document.getElementById('designTableBody');
        tbody.innerHTML = designs.map(function(d) {
          const ORDER = ['XS','S','M','L','XL','XXL'];
          const tallasHtml = Object.entries(d.tallas)
            .sort(function(a, b) { return ORDER.indexOf(a[0]) - ORDER.indexOf(b[0]); })
            .map(function(e) { return `<span class="talla-chip">${e[0]}×${e[1]}</span>`; }).join('');
          const ingreso = d.subtotal * 95000;
          const costo = d.subtotal * 49000;
          const margenD = ingreso - costo;
          return `<tr>
            <td style="color:var(--white);font-family:'Bebas Neue',sans-serif;font-size:.85rem;letter-spacing:.08em">${d.nombre}</td>
            <td>${tallasHtml}</td>
            <td style="text-align:center;color:var(--cream)">${d.subtotal}</td>
            <td style="color:var(--gold)">$${ingreso.toLocaleString('es-CO')}</td>
            <td style="color:var(--red)">$${costo.toLocaleString('es-CO')}</td>
            <td style="color:#4a9a4a">$${margenD.toLocaleString('es-CO')}</td>
          </tr>`;
        }).join('');
        document.getElementById('designTable').style.display = 'table';
      }
    } catch(e) {
      document.getElementById('summaryCards').innerHTML = '<p style="font-size:.6rem;color:var(--red);grid-column:1/-1">Error cargando resumen.</p>';
    }
  }

  async function loadLotes() {
    const lista = document.getElementById('lotesLista');
    try {
      const res = await fetch('/.netlify/functions/produccion', { headers: authH() });
      const lotes = await res.json();
      if (!lotes.length) {
        lista.innerHTML = '<p style="font-size:.6rem;color:#444;letter-spacing:.2em">No hay órdenes de producción todavía.</p>'; return;
      }
      lista.innerHTML = lotes.map(function(l) {
        const snap = l.snapshot || {};
        const fecha = new Date(l.created_at).toLocaleDateString('es-CO', { day:'2-digit', month:'short', year:'numeric' });
        const estados = ['borrador','en_produccion','listo','entregado'];
        const estadoOpts = estados.map(function(e) {
          return `<option value="${e}"${l.estado===e?' selected':''}>${e.replace('_',' ')}</option>`;
        }).join('');
        return `<div class="lote-card">
          <div class="lote-card-top">
            <div><p class="lote-nombre">${l.nombre}</p><p class="lote-fecha">${fecha}</p></div>
            <span class="lote-estado-badge estado-${l.estado}">${l.estado.replace('_',' ')}</span>
          </div>
          ${snap.totalUnidades ? `<div class="lote-stats">
            <span class="lote-stat"><strong>${snap.totalUnidades}</strong> unidades</span>
            <span class="lote-stat"><strong>${snap.pedidosCount}</strong> pedidos</span>
            <span class="lote-stat" style="color:var(--gold)"><strong>$${(snap.totalIngresos||0).toLocaleString('es-CO')}</strong> ingresos</span>
            <span class="lote-stat" style="color:#4a9a4a"><strong>$${(snap.margen||0).toLocaleString('es-CO')}</strong> margen</span>
          </div>` : ''}
          ${snap.designs && snap.designs.length ? `<div style="margin:.6rem 0">
            <p style="font-size:.45rem;letter-spacing:.3em;color:var(--red);text-transform:uppercase;margin-bottom:.4rem">✦ Artes para taller</p>
            ${snap.designs.map(function(d) {
              return `<div style="display:flex;justify-content:space-between;align-items:center;padding:.3rem 0;border-bottom:1px solid #161616">
                <span style="font-size:.58rem;color:var(--cream)">${d.nombre} <span style="color:#555;font-size:.5rem">(${d.subtotal} u)</span></span>
                <div style="display:flex;gap:.3rem;flex-wrap:wrap">
                  ${d.arte_url
                    ? `<a href="${d.arte_url}" target="_blank" rel="noopener" class="lote-action" style="font-size:.42rem;padding:.2rem .5rem;text-decoration:none">↓ Diseño</a>`
                    : `<span style="font-size:.45rem;color:#333;letter-spacing:.1em">sin diseño</span>`}
                  ${d.etiqueta_url
                    ? `<a href="${d.etiqueta_url}" target="_blank" rel="noopener" class="lote-action" style="font-size:.42rem;padding:.2rem .5rem;text-decoration:none;border-color:#3a6a5a;color:#4a9a8a">↓ Etiqueta</a>`
                    : ''}
                </div>
              </div>`;
            }).join('')}
          </div>` : ''}
          ${l.notas ? `<p style="font-size:.6rem;color:var(--light);margin-bottom:.5rem;line-height:1.7">${l.notas}</p>` : ''}
          <div style="margin-bottom:.6rem">
            <select onchange="updateLoteEstado('${l.id}',this.value)"
              style="font-family:'Space Mono',monospace;font-size:.5rem;letter-spacing:.15em;background:#111;border:1px solid #2a2a2a;border-bottom:1px solid var(--red);color:var(--cream);padding:.35rem .6rem;cursor:pointer;-webkit-appearance:none">
              ${estadoOpts}
            </select>
          </div>
          <div class="lote-actions">
            <button class="lote-action primary" onclick="printOrden('${l.id}')">⎙ Orden para taller</button>
            <button class="lote-action" onclick="toggleLotePedidos('${l.id}', ${JSON.stringify(l.pedidos_ids || [])})">≡ Ver pedidos</button>
            <button class="lote-action" onclick="deleteLote('${l.id}','${l.nombre.replace(/'/g, "\\'")}')">✕ Eliminar</button>
          </div>
          <div id="lote-pedidos-${l.id}" style="display:none;margin-top:1rem;border-top:1px solid #1a1a1a;padding-top:1rem">
            <p style="font-size:.45rem;letter-spacing:.3em;color:#555;text-transform:uppercase;margin-bottom:.6rem">Cargando pedidos...</p>
          </div>
        </div>`;
      }).join('');
    } catch(e) { lista.innerHTML = '<p style="font-size:.6rem;color:var(--red)">Error cargando lotes.</p>'; }
  }

  async function toggleLotePedidos(loteId, pedidosIds) {
    const el = document.getElementById('lote-pedidos-' + loteId);
    if (!el) return;
    if (el.style.display === 'block') { el.style.display = 'none'; return; }
    el.style.display = 'block';
    if (!pedidosIds.length) {
      el.innerHTML = '<p style="font-size:.55rem;color:#555;letter-spacing:.15em">No hay pedidos asociados a este lote.</p>'; return;
    }
    try {
      const res = await fetch('/.netlify/functions/get-orders', { headers: authH() });
      const orders = await res.json();
      const loteOrders = orders.filter(function(o) { return pedidosIds.includes(o.id); });
      if (!loteOrders.length) {
        el.innerHTML = '<p style="font-size:.55rem;color:#555;letter-spacing:.15em">No se encontraron los pedidos.</p>'; return;
      }
      el.innerHTML = '<p style="font-size:.45rem;letter-spacing:.3em;color:var(--red);text-transform:uppercase;margin-bottom:.6rem">✦ Pedidos incluidos</p>' +
        '<table style="width:100%;border-collapse:collapse;font-size:.58rem">' +
        '<thead><tr>' +
        '<th style="text-align:left;padding:.4rem .6rem;border-bottom:1px solid #1a1a1a;font-size:.42rem;letter-spacing:.25em;color:#555;text-transform:uppercase">Cliente</th>' +
        '<th style="text-align:left;padding:.4rem .6rem;border-bottom:1px solid #1a1a1a;font-size:.42rem;letter-spacing:.25em;color:#555;text-transform:uppercase">Ciudad</th>' +
        '<th style="text-align:left;padding:.4rem .6rem;border-bottom:1px solid #1a1a1a;font-size:.42rem;letter-spacing:.25em;color:#555;text-transform:uppercase">Productos</th>' +
        '<th style="text-align:right;padding:.4rem .6rem;border-bottom:1px solid #1a1a1a;font-size:.42rem;letter-spacing:.25em;color:#555;text-transform:uppercase">Total</th>' +
        '</tr></thead><tbody>' +
        loteOrders.map(function(o) {
          const items = Array.isArray(o.items) ? o.items : [];
          return '<tr>' +
            '<td style="padding:.45rem .6rem;border-bottom:1px solid #111;color:var(--cream)">' + (o.nombre||'—') + '<span style="display:block;font-size:.5rem;color:#555">' + (o.email||o.telefono||'') + '</span></td>' +
            '<td style="padding:.45rem .6rem;border-bottom:1px solid #111;color:var(--light)">' + (o.ciudad||'—') + '</td>' +
            '<td style="padding:.45rem .6rem;border-bottom:1px solid #111;color:var(--light)">' + items.map(function(i) { return i.name + ' T.' + i.size; }).join(', ') + '</td>' +
            '<td style="padding:.45rem .6rem;border-bottom:1px solid #111;color:var(--gold);text-align:right">$' + (o.total||0).toLocaleString('es-CO') + '</td>' +
            '</tr>';
        }).join('') +
        '</tbody></table>';
    } catch(e) { el.innerHTML = '<p style="font-size:.55rem;color:var(--red)">Error cargando pedidos.</p>'; }
  }

  async function updateLoteEstado(id, estado) {
    await fetch('/.netlify/functions/produccion', {
      method: 'PATCH',
      headers: authH({ 'Content-Type': 'application/json' }),
      body: JSON.stringify({ id, estado }),
    });
  }

  async function deleteLote(id, nombre) {
    if (!confirm(`¿Eliminar la orden "${nombre}"?`)) return;
    await fetch(`/.netlify/functions/produccion?id=${id}`, { method: 'DELETE', headers: authH() });
    loadLotes();
  }

  function crearLote() {
    document.getElementById('loteNombre').value = '';
    document.getElementById('loteNotas').value = '';
    document.getElementById('loteModalMsg').textContent = '';
    document.getElementById('loteModal').classList.add('open');
  }
  function closeLoteModal() { document.getElementById('loteModal').classList.remove('open'); }

  async function saveLote() {
    const nombre = document.getElementById('loteNombre').value.trim();
    const notas = document.getElementById('loteNotas').value.trim();
    const msgEl = document.getElementById('loteModalMsg');
    msgEl.textContent = '';
    if (!nombre) { msgEl.textContent = '✕ El nombre es obligatorio.'; msgEl.className = 'modal-msg error'; return; }
    const res = await fetch('/.netlify/functions/produccion', {
      method: 'POST',
      headers: authH({ 'Content-Type': 'application/json' }),
      body: JSON.stringify({ nombre, notas }),
    });
    const data = await res.json();
    if (!res.ok || !data.success) { msgEl.textContent = `✕ ${data.error || 'Error creando lote'}`; msgEl.className = 'modal-msg error'; return; }
    msgEl.textContent = '✔ Orden creada.'; msgEl.className = 'modal-msg success';
    setTimeout(function() { closeLoteModal(); loadLotes(); loadProduccionSummary(); }, 800);
  }

  async function printOrden(loteId) {
