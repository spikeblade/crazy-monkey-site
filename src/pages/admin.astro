---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Panel Admin — CRAZY MONKEY" noindex={true}>
  <style is:global>
  :root{--green:#2a6a2a}
  #loginScreen{min-height:100vh;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:1.5rem;padding:2rem}
  .login-logo{font-family:'Cinzel Decorative',serif;font-size:2rem;color:var(--white)}
  .login-logo span{color:var(--red)}
  .login-sub{font-size:.55rem;letter-spacing:.4em;color:var(--light);text-transform:uppercase}
  .login-form{display:flex;flex-direction:column;gap:.8rem;width:100%;max-width:320px}
  .login-input{background:#111;border:1px solid #2a2a2a;border-bottom:1px solid var(--red);color:var(--cream);font-family:'Space Mono',monospace;font-size:.8rem;padding:.8rem 1rem;outline:none;width:100%}
  .login-input:focus{border-color:var(--cream)}
  .login-btn{font-family:'Bebas Neue',sans-serif;font-size:1rem;letter-spacing:.3em;color:var(--black);background:var(--red);border:none;padding:.8rem;cursor:pointer;clip-path:polygon(6px 0%,100% 0%,calc(100% - 6px) 100%,0% 100%);transition:background .2s}
  .login-btn:hover{background:var(--cream)}
  .login-error{font-size:.6rem;color:var(--red);text-align:center;min-height:1rem}
  #adminPanel{display:none;padding:2rem}
  .admin-header{display:flex;justify-content:space-between;align-items:center;border-bottom:1px solid #1a1a1a;padding-bottom:1.5rem;margin-bottom:2rem;flex-wrap:wrap;gap:1rem}
  .admin-logo{font-family:'Cinzel Decorative',serif;font-size:1.4rem;color:var(--white)}
  .admin-logo span{color:var(--red)}
  .admin-title{font-size:.55rem;letter-spacing:.4em;color:var(--light);text-transform:uppercase;margin-top:.2rem}
  .admin-actions{display:flex;gap:.8rem;align-items:center;flex-wrap:wrap}
  .refresh-btn{font-family:'Space Mono',monospace;font-size:.55rem;letter-spacing:.2em;color:var(--light);background:none;border:1px solid #2a2a2a;padding:.5rem 1rem;cursor:pointer;text-transform:uppercase;transition:border-color .2s,color .2s}
  .refresh-btn:hover{border-color:var(--red);color:var(--cream)}
  .logout-btn{font-family:'Space Mono',monospace;font-size:.5rem;letter-spacing:.2em;color:#444;background:none;border:none;cursor:pointer;text-transform:uppercase;text-decoration:underline;text-underline-offset:3px}
  .session-warn{color:#c8a84b !important;animation:sessionPulse 2s ease-in-out infinite}
  .session-critical{color:#c94a4a !important}
  @keyframes sessionPulse{0%,100%{opacity:.7}50%{opacity:1}}
  .stats-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:1rem;margin-bottom:2rem}
  .stat-card{background:var(--deep);border:1px solid #1e1e1e;padding:1.2rem;text-align:center}
  .stat-num{font-family:'Bebas Neue',sans-serif;font-size:2.2rem;letter-spacing:.05em;color:var(--white)}
  .stat-label{font-size:.5rem;letter-spacing:.3em;color:var(--light);text-transform:uppercase;margin-top:.2rem}
  .filter-row{display:flex;gap:.5rem;margin-bottom:1.5rem;flex-wrap:wrap}
  .filter-btn{font-family:'Space Mono',monospace;font-size:.5rem;letter-spacing:.2em;color:var(--light);background:none;border:1px solid #1e1e1e;padding:.4rem .9rem;cursor:pointer;text-transform:uppercase;transition:all .2s}
  .filter-btn.active,.filter-btn:hover{border-color:var(--red);color:var(--cream)}
  .orders-wrap{overflow-x:auto}
  .orders-table{width:100%;border-collapse:collapse;font-size:.65rem;min-width:700px}
  .orders-table th{font-size:.5rem;letter-spacing:.3em;color:var(--red);text-transform:uppercase;padding:.8rem 1rem;border-bottom:1px solid #1e1e1e;text-align:left;white-space:nowrap}
  .orders-table td{padding:.9rem 1rem;border-bottom:1px solid #111;vertical-align:top;color:var(--cream)}
  .orders-table tr:hover td{background:rgba(255,255,255,.02)}
  .order-name{font-family:'Bebas Neue',sans-serif;font-size:.9rem;letter-spacing:.08em;color:var(--white)}
  .order-tel{font-size:.55rem;color:var(--light);margin-top:.15rem}
  .order-location{font-size:.6rem;color:var(--light)}
  .order-items-list{display:flex;flex-direction:column;gap:.2rem}
  .order-item-line{font-size:.58rem;color:var(--cream)}
  .order-item-line span{color:var(--red);margin-left:.3rem}
  .order-total{font-family:'Space Mono',monospace;font-size:.7rem;color:var(--gold);white-space:nowrap}
  .order-date{font-size:.55rem;color:var(--light);white-space:nowrap}
  .status-select{font-family:'Space Mono',monospace;font-size:.5rem;letter-spacing:.15em;background:#111;border:1px solid #2a2a2a;color:var(--cream);padding:.3rem .5rem;cursor:pointer;text-transform:uppercase;-webkit-appearance:none;appearance:none;width:100%;transition:border-color .2s}
  .status-select:focus{outline:none;border-color:var(--red)}
  .status-select option{background:#111}
  .estado-pendiente{color:var(--gold)}
  .estado-confirmado{color:#4a9a4a}
  .estado-enviado{color:#4a7aaa}
  .estado-entregado{color:var(--light)}
  .estado-revisar_stock{color:#c94a4a}
  .revisar-stock-banner{background:rgba(201,74,74,.08);border-left:3px solid #c94a4a;padding:.5rem .8rem;margin-bottom:.4rem;font-size:.55rem;letter-spacing:.15em;color:#c94a4a;text-transform:uppercase}
  .wa-btn{display:inline-block;font-size:.5rem;letter-spacing:.15em;color:#2a8a2a;background:none;border:1px solid #1a3a1a;padding:.3rem .6rem;cursor:pointer;text-transform:uppercase;text-decoration:none;transition:border-color .2s,color .2s;white-space:nowrap}
  .wa-btn:hover{border-color:#2a8a2a;color:#4aaa4a}
  .empty-state{text-align:center;padding:4rem 2rem;color:#333;font-size:.65rem;letter-spacing:.2em}
  .loading{text-align:center;padding:3rem;color:#444;font-size:.6rem;letter-spacing:.3em}
  @media(max-width:600px){#adminPanel{padding:1rem}.admin-header{flex-direction:column;align-items:flex-start;gap:1rem}.stats-grid{grid-template-columns:repeat(2,1fr)}}
  .prod-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1rem;margin-top:1rem}
  .prod-card{background:var(--deep);border:1px solid #1e1e1e;padding:1.2rem;position:relative;transition:border-color .2s}
  .prod-card.inactive{opacity:.45}
  .prod-card:hover{border-color:#2a2a2a}
  .prod-card-img{width:100%;aspect-ratio:16/9;object-fit:cover;filter:saturate(.8);margin-bottom:.8rem}
  .prod-card-name{font-family:'Bebas Neue',sans-serif;font-size:.95rem;letter-spacing:.08em;color:var(--white);margin-bottom:.2rem;line-height:1.2}
  .prod-card-col{font-size:.5rem;letter-spacing:.3em;color:var(--red);text-transform:uppercase;margin-bottom:.6rem}
  .prod-card-actions{display:flex;gap:.5rem;flex-wrap:wrap;margin-top:.8rem;padding-top:.8rem;border-top:1px solid #1a1a1a}
  .prod-action-btn{font-family:'Space Mono',monospace;font-size:.48rem;letter-spacing:.15em;background:none;border:1px solid #2a2a2a;color:var(--light);padding:.35rem .7rem;cursor:pointer;text-transform:uppercase;transition:all .2s;white-space:nowrap}
  .prod-action-btn:hover{border-color:var(--cream);color:var(--cream)}
  .prod-action-btn.danger:hover{border-color:var(--red);color:var(--red)}
  .prod-action-btn.toggle-on{border-color:#2a6a2a;color:#4a9a4a}
  .prod-action-btn.toggle-off{border-color:#555;color:#555}
  .prod-status{position:absolute;top:.8rem;right:.8rem;font-size:.45rem;letter-spacing:.2em;padding:.2rem .6rem;border-radius:2px;text-transform:uppercase}
  .prod-status.active{background:rgba(74,154,74,.15);color:#4a9a4a}
  .prod-status.inactive{background:rgba(85,85,85,.15);color:#555}
  .stock-bar-wrap{margin-top:.5rem;background:#111;height:3px;border-radius:2px;overflow:hidden}
  .stock-bar{height:100%;border-radius:2px;transition:width .4s ease}
  .stock-bar-green{background:#2a6a2a}
  .stock-bar-gold{background:var(--gold)}
  .stock-bar-red{background:var(--red)}
  .stock-info{font-size:.48rem;letter-spacing:.15em;color:#555;text-transform:uppercase;margin-top:.3rem}
  .stock-info.warning{color:var(--gold)}
  .stock-info.danger{color:var(--red)}
  .new-prod-btn{font-family:'Bebas Neue',sans-serif;font-size:.9rem;letter-spacing:.25em;color:var(--black);background:var(--red);border:none;padding:.65rem 1.5rem;cursor:pointer;clip-path:polygon(6px 0%,100% 0%,calc(100% - 6px) 100%,0% 100%);transition:background .2s;margin-bottom:1.5rem}
  .new-prod-btn:hover{background:var(--cream)}
  .modal-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.85);z-index:50000;align-items:center;justify-content:center;padding:2rem}
  .modal-overlay.open{display:flex}
  .modal-box{background:#0d0d0d;border:1px solid #2a2a2a;border-top:3px solid var(--red);padding:2rem;width:100%;max-width:560px;max-height:90vh;overflow-y:auto}
  .modal-title{font-family:'Bebas Neue',sans-serif;font-size:1.3rem;letter-spacing:.15em;color:var(--white);margin-bottom:1.5rem}
  .modal-field{display:flex;flex-direction:column;gap:.3rem;margin-bottom:1rem}
  .modal-field label{font-size:.48rem;letter-spacing:.35em;color:var(--light);text-transform:uppercase}
  .modal-field input,.modal-field textarea,.modal-field select{background:#111;border:1px solid #2a2a2a;border-bottom:1px solid var(--red);color:var(--cream);font-family:'Space Mono',monospace;font-size:.7rem;padding:.6rem .9rem;outline:none;resize:none;width:100%}
  .modal-field input:focus,.modal-field textarea:focus,.modal-field select:focus{border-color:var(--cream)}
  .modal-field select option{background:#111}
  .modal-actions{display:flex;gap:.8rem;margin-top:1.2rem;flex-wrap:wrap}
  .modal-save{font-family:'Bebas Neue',sans-serif;font-size:.9rem;letter-spacing:.25em;color:var(--black);background:var(--red);border:none;padding:.65rem 1.5rem;cursor:pointer;clip-path:polygon(6px 0%,100% 0%,calc(100% - 6px) 100%,0% 100%);transition:background .2s}
  .modal-save:hover{background:var(--cream)}
  .modal-cancel{font-family:'Space Mono',monospace;font-size:.55rem;letter-spacing:.2em;background:none;border:1px solid #2a2a2a;color:var(--light);padding:.65rem 1.2rem;cursor:pointer;text-transform:uppercase;transition:all .2s}
  .modal-cancel:hover{border-color:var(--cream);color:var(--cream)}
  .modal-msg{font-size:.6rem;margin-top:.6rem;min-height:1rem}
  .modal-msg.error{color:#e02020}
  .modal-msg.success{color:#4a9a4a}
  /* Search */
  .search-orders-wrap{margin-bottom:1rem}
  .search-orders-input{width:100%;background:#111;border:1px solid #2a2a2a;border-bottom:1px solid var(--red);color:var(--cream);font-family:'Space Mono',monospace;font-size:.65rem;padding:.6rem 1rem;outline:none}
  .search-orders-input:focus{border-color:var(--cream)}
  .search-orders-input::placeholder{color:#444}
  /* Tracking */
  .tracking-badge{font-size:.48rem;letter-spacing:.15em;color:#4a9a5a;text-transform:uppercase;display:block;margin-bottom:.2rem}
  .tracking-num-cell{font-size:.55rem;color:var(--cream);display:block}
  .btn-tracking{font-family:'Space Mono',monospace;font-size:.45rem;letter-spacing:.15em;background:none;border:1px solid #2a3a2a;color:#4a7a4a;padding:.3rem .6rem;cursor:pointer;text-transform:uppercase;transition:all .2s;white-space:nowrap}
  .btn-tracking:hover{border-color:#4a9a5a;color:#4a9a5a}
  /* Toast notificación pedido nuevo */
  #newOrderToast{position:fixed;bottom:2rem;right:2rem;background:#b01a1a;color:#f0ebe0;font-family:'Space Mono',monospace;font-size:.55rem;letter-spacing:.15em;padding:.8rem 1.5rem;z-index:99999;display:none;animation:slideIn .3s ease;border-left:3px solid var(--gold)}
  @keyframes slideIn{from{transform:translateX(120%)}to{transform:translateX(0)}}
  /* Clientes panel */
  .clientes-table{width:100%;border-collapse:collapse;font-size:.6rem}
  .clientes-table th{font-size:.45rem;letter-spacing:.3em;color:var(--red);text-transform:uppercase;padding:.6rem .8rem;border-bottom:1px solid #1e1e1e;text-align:left;background:var(--deep)}
  .clientes-table td{padding:.7rem .8rem;border-bottom:1px solid #111;vertical-align:top}
  .clientes-table tr:hover td{background:rgba(255,255,255,.015)}
  .cliente-nombre{color:var(--cream);font-size:.65rem;display:block}
  .cliente-email{color:var(--light);font-size:.52rem;display:block;margin-top:.1rem}
  .cliente-tel{color:#555;font-size:.5rem;display:block;margin-top:.1rem}
  .cliente-pedidos{font-family:'Bebas Neue',sans-serif;font-size:1.1rem;color:var(--white);line-height:1}
  .cliente-gastado{color:var(--gold);font-size:.65rem;display:block;margin-top:.1rem}
  .an-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:1rem;margin-bottom:2rem}
  .an-card{background:var(--deep);border:1px solid #1e1e1e;padding:1.3rem;position:relative;overflow:hidden}
  .an-card-accent{position:absolute;top:0;left:0;width:3px;height:100%;background:var(--red)}
  .an-card.gold .an-card-accent{background:var(--gold)}
  .an-card.green .an-card-accent{background:#4a9a5a}
  .an-num{font-family:'Bebas Neue',sans-serif;font-size:1.8rem;letter-spacing:.05em;color:var(--white);line-height:1}
  .an-num.small{font-size:1.3rem}
  .an-label{font-size:.48rem;letter-spacing:.3em;color:var(--light);text-transform:uppercase;margin-top:.3rem}
  .an-delta{font-size:.5rem;letter-spacing:.1em;margin-top:.4rem}
  .an-delta.up{color:#4a9a5a}
  .an-delta.down{color:#c94a4a}
  .an-delta.neutral{color:#555}
  .an-section{margin-bottom:2rem}
  .an-section-title{font-size:.5rem;letter-spacing:.4em;color:var(--red);text-transform:uppercase;margin-bottom:1rem;padding-bottom:.4rem;border-bottom:1px solid #1a1a1a}
  .an-chart{display:flex;align-items:flex-end;gap:4px;height:100px;padding-bottom:1.5rem;position:relative;border-bottom:1px solid #1a1a1a}
  .an-bar-wrap{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:flex-end;height:100%;gap:2px;position:relative}
  .an-bar{width:100%;background:var(--red);opacity:.7;min-height:2px;transition:opacity .2s;cursor:default}
  .an-bar:hover{opacity:1}
  .an-bar-label{font-size:.38rem;color:#444;letter-spacing:.1em;position:absolute;bottom:-1.2rem;white-space:nowrap}
  .an-hbar-wrap{display:flex;flex-direction:column;gap:.5rem}
  .an-hbar-row{display:flex;align-items:center;gap:.6rem;font-size:.6rem}
  .an-hbar-name{width:140px;color:var(--cream);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;flex-shrink:0}
  .an-hbar-track{flex:1;background:#111;height:8px;border-radius:1px;overflow:hidden}
  .an-hbar-fill{height:100%;background:var(--red);border-radius:1px;transition:width .4s ease}
  .an-hbar-fill.gold{background:var(--gold)}
  .an-hbar-fill.green{background:#4a9a5a}
  .an-hbar-val{font-size:.55rem;color:var(--light);width:40px;text-align:right;flex-shrink:0}
  .an-estado-grid{display:flex;flex-wrap:wrap;gap:.5rem}
  .an-estado-chip{background:rgba(255,255,255,.03);border:1px solid #1e1e1e;padding:.5rem 1rem;text-align:center;flex:1;min-width:90px}
  .an-estado-chip-num{font-family:'Bebas Neue',sans-serif;font-size:1.4rem;color:var(--white)}
  .an-estado-chip-label{font-size:.45rem;letter-spacing:.2em;color:var(--light);text-transform:uppercase}
  .cat-section{margin-bottom:2.5rem}
  .cat-section-title{font-family:'Bebas Neue',sans-serif;font-size:.9rem;letter-spacing:.25em;color:var(--white);margin-bottom:1rem;padding-bottom:.5rem;border-bottom:1px solid #1e1e1e}
  .cat-list{display:flex;flex-direction:column;gap:.4rem;margin-bottom:1rem;max-height:240px;overflow-y:auto}
  .cat-item{display:flex;align-items:center;gap:.6rem;padding:.5rem .8rem;background:rgba(255,255,255,.02);border:1px solid #1a1a1a}
  .cat-item-name{flex:1;font-size:.65rem;color:var(--cream)}
  .cat-item-slug{font-size:.5rem;color:#444;letter-spacing:.1em;margin-left:.3rem}
  .cat-item-inactive{opacity:.45}
  .cat-btn{font-family:'Space Mono',monospace;font-size:.45rem;letter-spacing:.2em;background:none;border:1px solid #2a2a2a;color:var(--light);padding:.25rem .6rem;cursor:pointer;text-transform:uppercase;transition:all .2s;white-space:nowrap}
  .cat-btn:hover{border-color:var(--cream);color:var(--cream)}
  .cat-btn.danger:hover{border-color:var(--red);color:var(--red)}
  .cat-add-form{display:flex;gap:.5rem;flex-wrap:wrap;align-items:flex-end}
  .cat-add-form input{background:#111;border:1px solid #2a2a2a;border-bottom:1px solid var(--red);color:var(--cream);font-family:'Space Mono',monospace;font-size:.7rem;padding:.5rem .8rem;outline:none;flex:1;min-width:140px}
  .cat-add-form input:focus{border-color:var(--cream)}
  .cat-add-form input::placeholder{color:#444}
  .cat-add-btn{font-family:'Bebas Neue',sans-serif;font-size:.8rem;letter-spacing:.2em;color:var(--black);background:var(--red);border:none;padding:.55rem 1.2rem;cursor:pointer;white-space:nowrap;transition:background .2s}
  .cat-add-btn:hover{background:var(--cream)}
  .cat-msg{font-size:.55rem;color:var(--red);margin-top:.4rem;min-height:.8rem}
  .prod-section-title{font-family:'Bebas Neue',sans-serif;font-size:1.1rem;letter-spacing:.2em;color:var(--white);margin-bottom:1.2rem}
  .summary-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:1rem;margin-bottom:2rem}
  .summary-card{background:var(--deep);border:1px solid #1e1e1e;padding:1.2rem;text-align:center}
  .summary-card-num{font-family:'Bebas Neue',sans-serif;font-size:2rem;color:var(--white);line-height:1}
  .summary-card-num.green{color:#4a9a4a}
  .summary-card-num.gold{color:var(--gold)}
  .summary-card-num.red{color:var(--red)}
  .summary-card-label{font-size:.48rem;letter-spacing:.3em;color:var(--light);text-transform:uppercase;margin-top:.4rem}
  .design-table{width:100%;border-collapse:collapse;font-size:.65rem;margin-bottom:2rem}
  .design-table th{font-size:.48rem;letter-spacing:.3em;color:var(--red);text-transform:uppercase;padding:.6rem .8rem;border-bottom:1px solid #1e1e1e;text-align:left}
  .design-table td{padding:.7rem .8rem;border-bottom:1px solid #111;color:var(--cream);vertical-align:top}
  .design-table tr:hover td{background:rgba(255,255,255,.02)}
  .talla-chip{display:inline-block;font-size:.5rem;letter-spacing:.1em;background:rgba(176,26,26,.1);border:1px solid rgba(176,26,26,.2);color:var(--red);padding:.15rem .5rem;margin:.1rem;border-radius:2px}
  .lote-card{background:var(--deep);border:1px solid #1e1e1e;padding:1.5rem;margin-bottom:1rem;transition:border-color .2s}
  .lote-card:hover{border-color:#2a2a2a}
  .lote-card-top{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:.8rem;flex-wrap:wrap;gap:.5rem}
  .lote-nombre{font-family:'Bebas Neue',sans-serif;font-size:1.1rem;letter-spacing:.1em;color:var(--white)}
  .lote-fecha{font-size:.48rem;letter-spacing:.2em;color:var(--light);text-transform:uppercase}
  .lote-estado-badge{font-size:.45rem;letter-spacing:.2em;padding:.25rem .7rem;border-radius:2px;text-transform:uppercase;font-weight:500}
  .estado-borrador{background:rgba(85,85,85,.2);color:#555}
  .estado-en_produccion{background:rgba(200,168,75,.15);color:var(--gold)}
  .estado-listo{background:rgba(74,154,74,.15);color:#4a9a4a}
  .lote-stats{display:flex;gap:1.5rem;flex-wrap:wrap;margin-bottom:.8rem}
  .lote-stat{font-size:.55rem;color:var(--light)}
  .lote-stat strong{color:var(--cream)}
  .lote-actions{display:flex;gap:.5rem;flex-wrap:wrap;margin-top:.8rem;padding-top:.8rem;border-top:1px solid #1a1a1a}
  .lote-action{font-family:'Space Mono',monospace;font-size:.48rem;letter-spacing:.15em;background:none;border:1px solid #2a2a2a;color:var(--light);padding:.35rem .7rem;cursor:pointer;text-transform:uppercase;transition:all .2s;white-space:nowrap;text-decoration:none;display:inline-block}
  .lote-action:hover{border-color:var(--cream);color:var(--cream)}
  .lote-action.primary{border-color:var(--red);color:var(--red)}
  .lote-action.primary:hover{background:var(--red);color:var(--black)}
  .new-lote-btn{font-family:'Bebas Neue',sans-serif;font-size:.9rem;letter-spacing:.25em;color:var(--black);background:#3a7a5a;border:none;padding:.65rem 1.5rem;cursor:pointer;clip-path:polygon(6px 0%,100% 0%,calc(100% - 6px) 100%,0% 100%);transition:background .2s;margin-bottom:1.5rem}
  .new-lote-btn:hover{background:#4a9a7a}
  /* Upload de imágenes */
  .img-upload-zone{border:1px dashed #2a2a2a;background:#0a0a0a;cursor:pointer;min-height:110px;display:flex;align-items:center;justify-content:center;position:relative;transition:border-color .2s;overflow:hidden}
  .img-upload-zone:hover,.img-upload-zone.dragover{border-color:var(--red);background:rgba(176,26,26,.04)}
  .img-upload-preview{max-width:100%;max-height:200px;object-fit:contain;display:none}
