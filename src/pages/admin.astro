</head><body>
<h1>CRAZY MONKEY — Orden de Producción</h1>
<div class="meta"><strong>Lote:</strong> ${lote.nombre}<br><strong>Fecha:</strong> ${fecha}<br><strong>Estado:</strong> ${lote.estado.replace('_',' ')}<br><strong>Pedidos incluidos:</strong> ${snap.pedidosCount || '—'}<br><strong>Costo por unidad:</strong> $${(lote.costo_unit||49000).toLocaleString('es-CO')} COP</div>
${lote.notas ? `<div class="notas"><strong>Instrucciones:</strong><br>${lote.notas}</div>` : ''}
<table><thead><tr><th>#</th><th>Diseño</th><th>Desglose por talla</th><th>Total unidades</th></tr></thead>
<tbody>${designs.map(function(d, i) {
  const tallasStr = Object.entries(d.tallas).sort(function(a,b){ return ORDER.indexOf(a[0])-ORDER.indexOf(b[0]); }).map(function(e){ return e[0]+': '+e[1]; }).join(' · ');
  return `<tr><td>${i+1}</td><td><strong>${d.nombre}</strong></td><td>${tallasStr}</td><td><strong>${d.subtotal}</strong></td></tr>`;
}).join('')}</tbody>
<tfoot><tr><td colspan="3" style="text-align:right;font-weight:bold">TOTAL</td><td><strong>${snap.totalUnidades||0}</strong></td></tr></tfoot>
</table>
<div class="totals">
<div class="totals-row"><span>Ingresos confirmados</span><span>$${(snap.totalIngresos||0).toLocaleString('es-CO')} COP</span></div>
<div class="totals-row"><span>Costo de producción (${snap.totalUnidades||0} × $${(lote.costo_unit||49000).toLocaleString('es-CO')})</span><span>$${(snap.totalCosto||0).toLocaleString('es-CO')} COP</span></div>
<div class="totals-row"><span>Margen bruto</span><span>$${(snap.margen||0).toLocaleString('es-CO')} COP</span></div>
</div>
<h2 style="font-size:1rem;letter-spacing:.1em;border-bottom:2px solid #b01a1a;padding-bottom:.5rem;margin:2rem 0 1rem">Artes para Impresión</h2>
${designs.some(function(d) { return d.arte_url || d.etiqueta_url; }) ? `<table><thead><tr><th>Diseño</th><th>Arte diseño</th><th>Arte etiqueta</th></tr></thead><tbody>${designs.map(function(d) {
  if (!d.arte_url && !d.etiqueta_url) return '';
  return `<tr><td><strong>${d.nombre}</strong></td><td>${d.arte_url ? `<a href="${d.arte_url}" target="_blank">↓ Descargar</a>` : '—'}</td><td>${d.etiqueta_url ? `<a href="${d.etiqueta_url}" target="_blank">↓ Descargar</a>` : '—'}</td></tr>`;
}).join('')}</tbody></table>` : '<p style="font-size:.75rem;color:#888;font-style:italic">No hay artes registrados. Agrégalos en Admin → Productos → Editar.</p>'}
<div class="firma"><div class="firma-box">Fecha de entrega comprometida</div><div class="firma-box">Recibido por (taller)</div><div class="firma-box">Aprobado por (Crazy Monkey)</div></div>
<br><button onclick="window.print()">⎙ Imprimir / Guardar PDF</button>
