---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Pedido Confirmado — CRAZY MONKEY" noindex={true}>
  <style is:global>
  body{min-height:100vh;display:flex;flex-direction:column}
  nav{position:fixed;top:0;left:0;right:0;z-index:1000;display:flex;justify-content:space-between;align-items:center;padding:1.2rem 2.5rem;background:rgba(8,8,8,0.98)}
  main{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:8rem 2rem 4rem;text-align:center;position:relative;z-index:1}
  .status-icon{font-size:3rem;margin-bottom:2rem;display:block;animation:pulse 2s ease-in-out infinite}
  @keyframes pulse{0%,100%{opacity:.6;transform:scale(1)}50%{opacity:1;transform:scale(1.08)}}
  .page-eyebrow{font-family:'Space Mono',monospace;font-size:.6rem;letter-spacing:.5em;color:var(--red);text-transform:uppercase;margin-bottom:1.2rem;opacity:0;animation:fadeUp .8s ease .2s forwards}
  .page-title{font-family:'UnifrakturMaguntia',cursive;font-size:clamp(42px,8vw,96px);line-height:.95;color:var(--white);text-shadow:0 0 60px rgba(176,26,26,.35),0 2px 0 #000;margin-bottom:1rem;opacity:0;animation:fadeUp 1s ease .4s forwards}
  .page-sub{font-family:'Bebas Neue',sans-serif;font-size:clamp(12px,2vw,20px);letter-spacing:.4em;color:var(--gold);margin-bottom:2rem;opacity:0;animation:fadeUp 1s ease .6s forwards}
  .page-divider{display:flex;align-items:center;gap:1rem;justify-content:center;margin:1.5rem auto 2.5rem;opacity:0;animation:fadeUp 1s ease .8s forwards}
  .page-divider span{display:block;width:60px;height:1px;background:linear-gradient(90deg,transparent,var(--red))}
  .page-divider span:last-child{background:linear-gradient(90deg,var(--red),transparent)}
  .page-divider em{font-size:.55rem;color:var(--light);letter-spacing:.3em;font-style:normal}
  .order-card{border:1px solid #1e1e1e;border-left:3px solid var(--red);background:rgba(176,26,26,.04);padding:2.5rem 3rem;max-width:560px;margin:0 auto 2.5rem;text-align:left;opacity:0;animation:fadeUp 1s ease 1s forwards}
  .order-card h3{font-family:'Bebas Neue',sans-serif;font-size:1rem;letter-spacing:.3em;color:var(--red);margin-bottom:1.5rem}
  .order-items{display:flex;flex-direction:column;gap:.8rem;margin-bottom:1.5rem}
  .order-item{display:flex;justify-content:space-between;align-items:baseline;gap:1rem;font-size:.7rem;border-bottom:1px solid #1a1a1a;padding-bottom:.8rem}
  .order-item:last-child{border-bottom:none}
  .order-item-name{color:var(--cream);line-height:1.5}
  .order-item-size{font-size:.55rem;color:var(--light);display:block;letter-spacing:.2em}
  .order-item-price{color:var(--gold);white-space:nowrap;font-family:'Space Mono',monospace}
  .order-total{display:flex;justify-content:space-between;font-family:'Bebas Neue',sans-serif;font-size:1.1rem;letter-spacing:.1em;color:var(--white);padding-top:1rem;border-top:1px solid #2a2a2a}
  .info-block{font-size:.65rem;line-height:2;color:var(--light);max-width:480px;margin:0 auto 2.5rem;opacity:0;animation:fadeUp 1s ease 1.2s forwards}
  .info-block strong{color:var(--cream)}
  .actions{display:flex;gap:1rem;flex-wrap:wrap;justify-content:center;opacity:0;animation:fadeUp 1s ease 1.4s forwards}
  .btn-primary{font-family:'Bebas Neue',sans-serif;font-size:1rem;letter-spacing:.3em;color:var(--black);background:var(--red);padding:.8rem 2.5rem;text-decoration:none;clip-path:polygon(8px 0%,100% 0%,calc(100% - 8px) 100%,0% 100%);transition:background .2s,transform .2s;display:inline-block}
  .btn-primary:hover{background:var(--cream);transform:translateY(-2px)}
  .btn-secondary{font-family:'Space Mono',monospace;font-size:.6rem;letter-spacing:.2em;color:var(--light);background:none;border:1px solid #2a2a2a;padding:.8rem 2rem;text-decoration:none;text-transform:uppercase;transition:border-color .2s,color .2s;display:inline-block}
  .btn-secondary:hover{border-color:var(--red);color:var(--cream)}
  .wa-note{margin-top:2.5rem;font-size:.6rem;letter-spacing:.2em;color:#444;opacity:0;animation:fadeUp 1s ease 1.6s forwards}
  .wa-link{color:var(--light);text-decoration:none;transition:color .2s}
  .wa-link:hover{color:var(--cream)}
  @media(max-width:768px){nav{padding:1rem 1.5rem}.order-card{padding:1.5rem}.actions{flex-direction:column;align-items:center}}
  </style>

<nav>
  <a href="/index.html" class="nav-logo">Crazy<span>M</span>onkey</a>
</nav>

<main>
  <span class="status-icon">✦</span>
  <p class="page-eyebrow">✦ Pago Confirmado ✦</p>
  <h1 class="page-title">Pedido<br>Recibido</h1>
  <p class="page-sub">Tu orden está en camino</p>
  <div class="page-divider"><span></span><em>Gracias por tu confianza</em><span></span></div>

  <div class="order-card" id="orderSummary">
    <h3>✦ Resumen de tu pedido</h3>
    <div class="order-items" id="orderItems">
      <p style="font-size:.65rem;color:var(--light)">Cargando tu pedido...</p>
    </div>
    <div class="order-total">
      <span>Total pagado</span>
      <span id="orderTotal">—</span>
    </div>
  </div>

  <div class="info-block">
    <strong>¿Qué sigue?</strong><br>
    Recibirás un mensaje de confirmación al teléfono registrado en MercadoPago.<br>
    El envío tarda entre <strong>3 a 5 días hábiles</strong> a cualquier punto de Colombia.<br>
    Si tienes alguna duda, escríbenos directamente.
  </div>

  <div class="actions">
    <a href="/index.html" class="btn-primary">Ver más diseños →</a>
    <a href="/estado-pedido.html" class="btn-secondary">Estado de mi pedido</a>
  </div>

  <p class="wa-note">
    ¿Problemas con el pago?
    <a href="https://wa.me/573016568222" target="_blank" rel="noopener" class="wa-link">Escríbenos al +57 301 656 8222</a>
  </p>
</main>

<script is:inline>
  var cart = JSON.parse(localStorage.getItem('cm_cart') || '[]');
  var itemsEl = document.getElementById('orderItems');
  var totalEl = document.getElementById('orderTotal');

  if (cart.length === 0) {
    itemsEl.innerHTML = '<p style="font-size:.65rem;color:var(--light)">No hay items registrados.</p>';
    totalEl.textContent = '—';
  } else {
    itemsEl.innerHTML = cart.map(function(item) {
      return '<div class="order-item"><div>' +
        '<span class="order-item-name">' + item.name + '</span>' +
        '<span class="order-item-size">Talla ' + item.size + '</span>' +
        '</div><span class="order-item-price">$' + (item.price || 95000).toLocaleString('es-CO') + ' COP</span></div>';
    }).join('');
    var total = cart.reduce(function(s, i) { return s + (i.price || 95000); }, 0);
    totalEl.textContent = '$' + total.toLocaleString('es-CO') + ' COP';
    localStorage.removeItem('cm_cart');
  }
</script>
</Layout>
